  "description": "Scatter plot showing the relationship between height and weight across 23 individuals in three categories. Strong positive correlation (r=0.95) — taller individuals tend to weigh more.",
  "height": 400,

  "legends": [
    {
      "encode": {
        "labels": {
          "update": {
            "fill": {
              "value": "#868e96"
            },
            "fontSize": {
              "value": 11
            }
          }
        },
        "title": {
          "update": {
            "fill": {
              "value": "#495057"
            },
            "fontSize": {
              "value": 12
            }
          }
        }
      },
      "fill": "color",
      "orient": "top-right",
      "title": "Category"
    }
  ],

  "marks": [
    {
      "encode": {
        "enter": {
          "shape": {
            "value": "circle"
          },
          "size": {
            "value": 80
          },
          "tooltip": {
            "signal": "{'Name': datum.label, 'Height (cm)': datum.x, 'Weight (kg)': datum.y, 'Category': datum.category}"
          }
        },
        "update": {
          "fill": {
            "field": "category",
            "scale": "color"
          },
          "fillOpacity": [
            {
              "test": "hovered === null || hovered.category === datum.category",
              "value": 0.7
            },
            {
              "value": 0.15
            }
          ],
          "stroke": {
            "field": "category",
            "scale": "color"
          },
          "strokeOpacity": [
            {
              "test": "hovered === null || hovered.category === datum.category",
              "value": 1
            },
            {
              "value": 0.1
            }
          ],
          "strokeWidth": {
            "value": 1
          },
          "x": {
            "field": "x",
            "scale": "x"
          },
          "y": {
            "field": "y",
            "scale": "y"
          }
        }
      },
      "from": {
        "data": "source"
      },
      "type": "symbol"
    }
  ],
  "padding": {
    "bottom": 16,
    "left": 24,
    "right": 24,
    "top": 16
  },

  "scales": [
    {
      "domain": {
        "data": "source",
        "field": "x"
      },
      "name": "x",
      "nice": true,
      "range": "width",
      "type": "linear",
      "zero": false
    },
    {
      "domain": {
        "data": "source",
        "field": "y"
      },
      "name": "y",
      "nice": true,
      "range": "height",
      "reverse": true,
      "type": "linear",
      "zero": false
    },
    {
      "domain": {
        "data": "source",
        "field": "category"
      },
      "name": "color",
      "range": [
        "#1c7ed6",
        "#e8590c",
        "#0ca678",
        "#f03e3e",
        "#ae3ec9",
        "#1098ad",
        "#74b816",
        "#d6336c"
      ],
      "type": "ordinal"
    }
  ],

  "signals": [
    {
      "name": "hovered",
      "on": [
        {
          "events": "symbol:pointerover",
          "update": "datum"
        },
        {
          "events": "symbol:pointerout",
          "update": "null"
        }
      ],
      "value": null
    }
  ],
  "title": {
    "anchor": "start",
    "fontSize": 16,
    "offset": 16,
    "subtitle": "Height vs. weight, 23 individuals (cm, kg)",
    "subtitleColor": "#868e96",
    "subtitleFontSize": 12,
    "text": "Height and weight correlate strongly across all groups (r=0.95)"
  },
  "width": 600
}
