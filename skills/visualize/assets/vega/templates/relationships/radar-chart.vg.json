{
  "_metadata": {
    "customization": [
      "Replace 'values' array with your data",
      "Update 'dimensions' signal array to match your dimension names — order controls angular placement",
      "Update 'products' signal array to match your product/series names",
      "All values must be on the same 0–100 scale; normalize before rendering if needed",
      "Update title, subtitle, and description to reflect your context"
    ],
    "dataFormat": "Array of objects with 'product' (nominal), 'dimension' (nominal), and 'value' (quantitative, 0–100) fields.",
    "note": "Radar charts are perceptually weak — angles and areas are hard to compare accurately. Use parallel coordinates when precision matters."
  },
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "autosize": {
    "contains": "padding",
    "type": "fit"
  },

  "config": {
    "aria": true,
    "axis": {
      "labelFont": "system-ui, -apple-system, sans-serif",
      "titleFont": "system-ui, -apple-system, sans-serif"
    },
    "legend": {
      "labelFont": "system-ui, -apple-system, sans-serif",
      "titleFont": "system-ui, -apple-system, sans-serif"
    },
    "title": {
      "font": "system-ui, -apple-system, sans-serif"
    }
  },

  "data": [
    {
      "name": "source",
      "transform": [
        {
          "as": "dimIndex",
          "expr": "indexof(dimensions, datum.dimension)",
          "type": "formula"
        },
        {
          "as": "angle",
          "expr": "(datum.dimIndex / nDim) * 2 * PI - PI / 2",
          "type": "formula"
        },
        {
          "as": "r",
          "expr": "(datum.value / 100) * radius",
          "type": "formula"
        },
        {
          "as": "px",
          "expr": "cx + datum.r * cos(datum.angle)",
          "type": "formula"
        },
        {
          "as": "py",
          "expr": "cy + datum.r * sin(datum.angle)",
          "type": "formula"
        }
      ],
      "values": [
        {
          "dimension": "Reliability",
          "product": "Product A",
          "value": 88
        },
        {
          "dimension": "Quality",
          "product": "Product A",
          "value": 82
        },
        {
          "dimension": "Performance",
          "product": "Product A",
          "value": 74
        },
        {
          "dimension": "Support",
          "product": "Product A",
          "value": 70
        },
        {
          "dimension": "Features",
          "product": "Product A",
          "value": 65
        },
        {
          "dimension": "Price",
          "product": "Product A",
          "value": 55
        },
        {
          "dimension": "Reliability",
          "product": "Product B",
          "value": 72
        },
        {
          "dimension": "Quality",
          "product": "Product B",
          "value": 70
        },
        {
          "dimension": "Performance",
          "product": "Product B",
          "value": 75
        },
        {
          "dimension": "Support",
          "product": "Product B",
          "value": 78
        },
        {
          "dimension": "Features",
          "product": "Product B",
          "value": 73
        },
        {
          "dimension": "Price",
          "product": "Product B",
          "value": 68
        },
        {
          "dimension": "Reliability",
          "product": "Product C",
          "value": 60
        },
        {
          "dimension": "Quality",
          "product": "Product C",
          "value": 65
        },
        {
          "dimension": "Performance",
          "product": "Product C",
          "value": 80
        },
        {
          "dimension": "Support",
          "product": "Product C",
          "value": 55
        },
        {
          "dimension": "Features",
          "product": "Product C",
          "value": 88
        },
        {
          "dimension": "Price",
          "product": "Product C",
          "value": 85
        }
      ]
    },
    {
      "name": "product_a",
      "source": "source",
      "transform": [
        {
          "expr": "datum.product === 'Product A'",
          "type": "filter"
        }
      ]
    },
    {
      "name": "product_b",
      "source": "source",
      "transform": [
        {
          "expr": "datum.product === 'Product B'",
          "type": "filter"
        }
      ]
    },
    {
      "name": "product_c",
      "source": "source",
      "transform": [
        {
          "expr": "datum.product === 'Product C'",
          "type": "filter"
        }
      ]
    },
    {
      "name": "axes",
      "transform": [
        {
          "as": "dimIndex",
          "start": 0,
          "stop": 6,
          "type": "sequence"
        },
        {
          "as": "angle",
          "expr": "(datum.dimIndex / 6) * 2 * PI - PI / 2",
          "type": "formula"
        },
        {
          "as": "x2",
          "expr": "cx + radius * cos(datum.angle)",
          "type": "formula"
        },
        {
          "as": "y2",
          "expr": "cy + radius * sin(datum.angle)",
          "type": "formula"
        },
        {
          "as": "label",
          "expr": "dimensions[datum.dimIndex]",
          "type": "formula"
        },
        {
          "as": "labelX",
          "expr": "cx + (radius + 20) * cos(datum.angle)",
          "type": "formula"
        },
        {
          "as": "labelY",
          "expr": "cy + (radius + 20) * sin(datum.angle)",
          "type": "formula"
        }
      ]
    },
    {
      "name": "rings",
      "transform": [
        {
          "as": "ringIndex",
          "start": 1,
          "stop": 5,
          "type": "sequence"
        },
        {
          "as": "r",
          "expr": "(datum.ringIndex / 4) * radius",
          "type": "formula"
        },
        {
          "as": "ringValue",
          "expr": "datum.ringIndex * 25",
          "type": "formula"
        }
      ]
    }
  ],
  "description": "Radar chart comparing 3 products across 6 dimensions. Product A leads in Reliability (88) and Quality (82). Product C scores highest on Price (85). Product B is well-rounded with no standout dimension.",
  "height": 480,

  "legends": [
    {
      "direction": "horizontal",
      "fill": "color",
      "labelColor": "#868e96",
      "labelFontSize": 12,
      "orient": "bottom",
      "padding": 8,
      "stroke": "color",
      "title": "Product",
      "titleColor": "#495057",
      "titleFontSize": 13
    }
  ],

  "marks": [
    {
      "encode": {
        "enter": {
          "stroke": {
            "value": "#dee2e6"
          },
          "strokeWidth": {
            "value": 1
          },
          "x": {
            "signal": "cx"
          },
          "x2": {
            "field": "x2"
          },
          "y": {
            "signal": "cy"
          },
          "y2": {
            "field": "y2"
          }
        }
      },
      "from": {
        "data": "axes"
      },
      "type": "rule"
    },
    {
      "encode": {
        "enter": {
          "endAngle": {
            "signal": "2 * PI"
          },
          "fill": {
            "value": "transparent"
          },
          "innerRadius": {
            "value": 0
          },
          "outerRadius": {
            "field": "r"
          },
          "startAngle": {
            "value": 0
          },
          "stroke": {
            "value": "#f1f3f5"
          },
          "strokeDash": {
            "value": [
              2,
              2
            ]
          },
          "strokeWidth": {
            "value": 1
          },
          "x": {
            "signal": "cx"
          },
          "y": {
            "signal": "cy"
          }
        }
      },
      "from": {
        "data": "rings"
      },
      "type": "arc"
    },
    {
      "encode": {
        "enter": {
          "baseline": {
            "value": "bottom"
          },
          "fill": {
            "value": "#adb5bd"
          },
          "fontSize": {
            "value": 9
          },
          "text": {
            "signal": "datum.ringValue + ''"
          },
          "x": {
            "signal": "cx + 4"
          },
          "y": {
            "signal": "cy - datum.r"
          }
        }
      },
      "from": {
        "data": "rings"
      },
      "type": "text"
    },
    {
      "encode": {
        "enter": {
          "defined": {
            "value": true
          },
          "strokeWidth": {
            "value": 2
          },
          "tooltip": {
            "signal": "{'Product': datum.product, 'Dimension': datum.dimension, 'Score': datum.value + ' / 100'}"
          },
          "x": {
            "field": "px"
          },
          "y": {
            "field": "py"
          }
        },
        "update": {
          "fill": {
            "value": "#1c7ed6"
          },
          "fillOpacity": [
            {
              "test": "hovered === null || hovered.product === 'Product A'",
              "value": 0.1
            },
            {
              "value": 0.02
            }
          ],
          "stroke": {
            "value": "#1c7ed6"
          },
          "strokeOpacity": [
            {
              "test": "hovered === null || hovered.product === 'Product A'",
              "value": 1
            },
            {
              "value": 0.2
            }
          ]
        }
      },
      "from": {
        "data": "product_a"
      },
      "sort": {
        "field": "dimIndex"
      },
      "type": "line"
    },
    {
      "encode": {
        "enter": {
          "defined": {
            "value": true
          },
          "strokeWidth": {
            "value": 2
          },
          "tooltip": {
            "signal": "{'Product': datum.product, 'Dimension': datum.dimension, 'Score': datum.value + ' / 100'}"
          },
          "x": {
            "field": "px"
          },
          "y": {
            "field": "py"
          }
        },
        "update": {
          "fill": {
            "value": "#e8590c"
          },
          "fillOpacity": [
            {
              "test": "hovered === null || hovered.product === 'Product B'",
              "value": 0.1
            },
            {
              "value": 0.02
            }
          ],
          "stroke": {
            "value": "#e8590c"
          },
          "strokeOpacity": [
            {
              "test": "hovered === null || hovered.product === 'Product B'",
              "value": 1
            },
            {
              "value": 0.2
            }
          ]
        }
      },
      "from": {
        "data": "product_b"
      },
      "sort": {
        "field": "dimIndex"
      },
      "type": "line"
    },
    {
      "encode": {
        "enter": {
          "defined": {
            "value": true
          },
          "strokeWidth": {
            "value": 2
          },
          "tooltip": {
            "signal": "{'Product': datum.product, 'Dimension': datum.dimension, 'Score': datum.value + ' / 100'}"
          },
          "x": {
            "field": "px"
          },
          "y": {
            "field": "py"
          }
        },
        "update": {
          "fill": {
            "value": "#0ca678"
          },
          "fillOpacity": [
            {
              "test": "hovered === null || hovered.product === 'Product C'",
              "value": 0.1
            },
            {
              "value": 0.02
            }
          ],
          "stroke": {
            "value": "#0ca678"
          },
          "strokeOpacity": [
            {
              "test": "hovered === null || hovered.product === 'Product C'",
              "value": 1
            },
            {
              "value": 0.2
            }
          ]
        }
      },
      "from": {
        "data": "product_c"
      },
      "sort": {
        "field": "dimIndex"
      },
      "type": "line"
    },
    {
      "encode": {
        "enter": {
          "align": {
            "signal": "abs(datum.labelX - cx) < 10 ? 'center' : datum.labelX > cx ? 'left' : 'right'"
          },
          "baseline": {
            "signal": "datum.labelY < cy - 10 ? 'bottom' : datum.labelY > cy + 10 ? 'top' : 'middle'"
          },
          "fill": {
            "value": "#495057"
          },
          "fontSize": {
            "value": 12
          },
          "fontWeight": {
            "value": "600"
          },
          "text": {
            "field": "label"
          },
          "x": {
            "field": "labelX"
          },
          "y": {
            "field": "labelY"
          }
        }
      },
      "from": {
        "data": "axes"
      },
      "type": "text"
    }
  ],
  "padding": {
    "bottom": 16,
    "left": 24,
    "right": 24,
    "top": 16
  },

  "scales": [
    {
      "domain": [
        "Product A",
        "Product B",
        "Product C"
      ],
      "name": "color",
      "range": [
        "#1c7ed6",
        "#e8590c",
        "#0ca678"
      ],
      "type": "ordinal"
    }
  ],

  "signals": [
    {
      "name": "cx",
      "value": 280
    },
    {
      "name": "cy",
      "value": 230
    },
    {
      "name": "radius",
      "value": 160
    },
    {
      "name": "dimensions",
      "value": [
        "Reliability",
        "Quality",
        "Performance",
        "Support",
        "Features",
        "Price"
      ]
    },
    {
      "name": "nDim",
      "update": "length(dimensions)"
    },
    {
      "name": "products",
      "value": [
        "Product A",
        "Product B",
        "Product C"
      ]
    },
    {
      "name": "hovered",
      "on": [
        {
          "events": "path:pointerover",
          "update": "datum"
        },
        {
          "events": "path:pointerout",
          "update": "null"
        }
      ],
      "value": null
    }
  ],
  "title": {
    "anchor": "start",
    "fontSize": 16,
    "offset": 16,
    "subtitle": "Product ratings across 6 dimensions, Q4 2024 (score 0–100)",
    "subtitleColor": "#868e96",
    "subtitleFontSize": 12,
    "text": "Product A leads on reliability; Product C wins on price"
  },
  "width": 600
}
