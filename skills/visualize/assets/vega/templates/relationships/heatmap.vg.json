  "description": "Heatmap showing commit activity across days of week and time of day. Peak activity on Wednesday at 09:00. Weekday afternoons consistently higher than mornings and evenings. Weekend activity is lower and more evenly spread.",
  "height": 280,

  "legends": [
    {
      "encode": {
        "labels": {
          "update": {
            "fill": {
              "value": "#868e96"
            },
            "fontSize": {
              "value": 11
            }
          }
        },
        "title": {
          "update": {
            "fill": {
              "value": "#495057"
            },
            "fontSize": {
              "value": 12
            }
          }
        }
      },
      "fill": "color",
      "orient": "right",
      "title": "Commits"
    }
  ],

  "marks": [
    {
      "encode": {
        "enter": {
          "tooltip": {
            "signal": "{'Day': datum.day, 'Hour': datum.hour, 'Commits': datum.value}"
          }
        },
        "update": {
          "cornerRadius": {
            "value": 2
          },
          "fill": {
            "field": "value",
            "scale": "color"
          },
          "height": {
            "band": 1,
            "offset": -1,
            "scale": "y"
          },
          "opacity": [
            {
              "test": "hovered === null || hovered.day === datum.day",
              "value": 1
            },
            {
              "value": 0.4
            }
          ],
          "width": {
            "band": 1,
            "offset": -1,
            "scale": "x"
          },
          "x": {
            "field": "hour",
            "scale": "x"
          },
          "y": {
            "field": "day",
            "scale": "y"
          }
        }
      },
      "from": {
        "data": "source"
      },
      "type": "rect"
    }
  ],
  "padding": {
    "bottom": 16,
    "left": 24,
    "right": 24,
    "top": 16
  },

  "scales": [
    {
      "domain": {
        "data": "source",
        "field": "hour",
        "sort": true
      },
      "name": "x",
      "padding": 0.05,
      "range": "width",
      "type": "band"
    },
    {
      "domain": {
        "data": "source",
        "field": "day",
        "sort": {
          "field": "day",
          "order": "ascending"
        }
      },
      "name": "y",
      "padding": 0.05,
      "range": "height",
      "type": "band"
    },
    {
      "domain": {
        "data": "source",
        "field": "value"
      },
      "name": "color",
      "nice": true,
      "range": {
        "scheme": "blues"
      },
      "type": "sequential",
      "zero": true
    }
  ],

  "signals": [
    {
      "name": "hovered",
      "on": [
        {
          "events": "rect:pointerover",
          "update": "datum"
        },
        {
          "events": "rect:pointerout",
          "update": "null"
        }
      ],
      "value": null
    }
  ],
  "title": {
    "anchor": "start",
    "fontSize": 16,
    "offset": 16,
    "subtitle": "Commit activity by day of week and hour of day (count)",
    "subtitleColor": "#868e96",
    "subtitleFontSize": 12,
    "text": "Wednesday afternoon is peak commit time, weekends trail off sharply"
  },
  "width": 600
}
