          "size": 221,
          "x": 211,
          "y": 2500
        },
        {
          "category": "Internet Services",
          "label": "Alphabet",
          "size": 182,
          "x": 282,
          "y": 1700
        },
        {
          "category": "E-commerce",
          "label": "Amazon",
          "size": 1540,
          "x": 574,
          "y": 1500
        },
        {
          "category": "Internet Services",
          "label": "Meta",
          "size": 77,
          "x": 117,
          "y": 850
        },
        {
          "category": "Semiconductors",
          "label": "NVIDIA",
          "size": 26,
