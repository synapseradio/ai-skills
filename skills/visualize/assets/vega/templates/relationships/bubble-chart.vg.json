{
  "_metadata": {
    "customization": [
      "Replace 'values' array with your data",
      "Change field names in scales, axes, and marks to match your data",
      "Update axes titles to include your units",
      "Adjust size scale range to control min/max bubble sizes",
      "Modify title and description for your context"
    ],
    "dataFormat": "Array of objects with 'label' (nominal identifier), 'x' (quantitative), 'y' (quantitative), 'size' (quantitative for bubble area), and 'category' (nominal for color) fields."
  },
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "autosize": {
    "contains": "padding",
    "type": "fit"
  },

  "axes": [
    {
      "domainColor": "#dee2e6",
      "grid": true,
      "gridColor": "#f1f3f5",
      "gridDash": [
        2,
        2
      ],
      "labelColor": "#868e96",
      "labelFontSize": 12,
      "orient": "bottom",
      "scale": "x",
      "tickColor": "#dee2e6",
      "title": "Revenue ($B)",
      "titleColor": "#495057",
      "titleFontSize": 13
    },
    {
      "domainColor": "#dee2e6",
      "grid": true,
      "gridColor": "#f1f3f5",
      "gridDash": [
        2,
        2
      ],
      "labelColor": "#868e96",
      "labelFontSize": 12,
      "orient": "left",
      "scale": "y",
      "tickColor": "#dee2e6",
      "title": "Market Cap ($B)",
      "titleColor": "#495057",
      "titleFontSize": 13
    }
  ],

  "config": {
    "aria": true,
    "axis": {
      "labelFont": "system-ui, -apple-system, sans-serif",
      "titleFont": "system-ui, -apple-system, sans-serif"
    },
    "title": {
      "font": "system-ui, -apple-system, sans-serif"
    }
  },

  "data": [
    {
      "name": "source",
      "values": [
        {
          "category": "Consumer Electronics",
