          "y": 650
        },
        {
          "category": "Entertainment",
          "label": "Netflix",
          "size": 13,
          "x": 32,
          "y": 195
        },
        {
          "category": "Software",
          "label": "Salesforce",
          "size": 73,
          "x": 31,
          "y": 215
        },
        {
          "category": "Software",
          "label": "Adobe",
          "size": 29,
          "x": 18,
          "y": 240
        },
        {
          "category": "Semiconductors",
          "label": "Intel",
          "size": 125,
