          "y": 125
        }
      ]
    }
  ],
  "description": "Bubble chart showing 15 technology companies. Position encodes revenue (x) and market cap (y). Bubble area encodes employee count with sqrt scaling. Strong positive correlation between revenue and market cap. Amazon is a notable outlier with the largest workforce.",
  "height": 440,

  "legends": [
    {
      "encode": {
        "labels": {
          "update": {
            "fill": {
              "value": "#868e96"
            },
            "fontSize": {
              "value": 11
            }
          }
        },
        "title": {
          "update": {
            "fill": {
              "value": "#495057"
            },
            "fontSize": {
              "value": 12
            }
          }
        }
      },
      "fill": "color",
      "orient": "top-right",
      "title": "Sector"
    }
  ],

  "marks": [
    {
      "encode": {
        "enter": {
          "shape": {
            "value": "circle"
          },
          "stroke": {
            "value": "#fff"
          },
          "strokeWidth": {
            "value": 1.5
          },
          "tooltip": {
            "signal": "{'Company': datum.label, 'Revenue ($B)': datum.x, 'Market Cap ($B)': datum.y, 'Employees (K)': datum.size, 'Sector': datum.category}"
          }
        },
        "update": {
          "fill": {
            "field": "category",
            "scale": "color"
          },
          "fillOpacity": [
            {
              "test": "hovered === null || hovered.category === datum.category",
              "value": 0.75
            },
            {
              "value": 0.15
            }
          ],
          "size": {
            "field": "size",
            "scale": "size"
          },
          "x": {
            "field": "x",
            "scale": "x"
          },
          "y": {
            "field": "y",
            "scale": "y"
          }
        }
      },
      "from": {
        "data": "source"
      },
      "type": "symbol"
    },
    {
      "encode": {
        "enter": {
          "align": {
            "value": "center"
          },
          "baseline": {
            "value": "middle"
          },
          "fill": {
            "value": "#495057"
          },
          "fontSize": {
            "value": 9
          }
        },
        "update": {
          "opacity": [
            {
              "test": "hovered === null || hovered.label === datum.label",
              "value": 1
            },
            {
              "value": 0.15
            }
          ],
          "text": {
            "field": "label"
          },
          "x": {
            "field": "x",
            "scale": "x"
          },
          "y": {
            "field": "y",
            "scale": "y"
          }
        }
      },
      "from": {
        "data": "source"
      },
      "type": "text"
    }
  ],
  "padding": {
    "bottom": 16,
    "left": 24,
    "right": 24,
    "top": 16
  },

  "scales": [
    {
      "domain": {
        "data": "source",
        "field": "x"
      },
      "name": "x",
      "nice": true,
      "range": "width",
      "type": "linear",
      "zero": false
    },
    {
      "domain": {
        "data": "source",
        "field": "y"
      },
      "name": "y",
      "nice": true,
      "range": "height",
      "reverse": true,
      "type": "linear",
      "zero": false
    },
    {
      "domain": {
        "data": "source",
        "field": "size"
      },
      "name": "size",
      "range": [
        50,
        3000
      ],
      "type": "sqrt",
      "zero": true
    },
    {
      "domain": {
        "data": "source",
        "field": "category"
      },
      "name": "color",
      "range": [
        "#1c7ed6",
        "#e8590c",
        "#0ca678",
        "#f03e3e",
        "#ae3ec9",
        "#1098ad",
        "#74b816",
        "#d6336c"
      ],
      "type": "ordinal"
    }
  ],

  "signals": [
    {
      "name": "hovered",
      "on": [
        {
          "events": "symbol:pointerover",
          "update": "datum"
        },
        {
          "events": "symbol:pointerout",
          "update": "null"
        }
      ],
      "value": null
    }
  ],
  "title": {
    "anchor": "start",
    "fontSize": 16,
    "offset": 16,
    "subtitle": "Revenue vs. market cap for 15 tech companies; bubble size = employees (thousands)",
    "subtitleColor": "#868e96",
    "subtitleFontSize": 12,
    "text": "Amazon's workforce dwarfs peers; NVIDIA commands outsized market cap per employee"
  },
  "width": 640
}
