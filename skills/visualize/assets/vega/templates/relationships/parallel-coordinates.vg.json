        }
      ]
    },
    {
      "name": "fields",
      "values": [
        {
          "field": "speed",
          "label": "Speed"
        },
        {
          "field": "efficiency",
          "label": "Efficiency"
        },
        {
          "field": "quality",
          "label": "Quality"
        },
        {
          "field": "cost",
          "label": "Cost"
        },
        {
          "field": "reliability",
          "label": "Reliability"
        }
      ]
    }
  ],
  "description": "Parallel coordinates chart comparing 15 products across 5 dimensions: speed, efficiency, quality, cost, and reliability. Grouped by 3 product categories.",
  "height": 420,

  "legends": [
    {
      "labelColor": "#495057",
      "labelFontSize": 11,
      "orient": "top-right",
      "stroke": "color",
      "symbolSize": 60,
      "symbolStrokeWidth": 2,
      "title": "Category",
      "titleColor": "#495057",
      "titleFontSize": 12
    }
  ],

  "marks": [
    {
      "from": {
        "data": "source"
      },
      "key": "datum.name",
      "marks": [
        {
          "encode": {
            "enter": {
              "defined": {
                "signal": "isValid(parent[datum.field])"
              },
              "strokeWidth": {
                "value": 1.5
              },
              "tooltip": {
                "signal": "{'Product': parent.name, 'Category': parent.category, 'Speed': parent.speed, 'Efficiency': parent.efficiency, 'Quality': parent.quality, 'Cost': parent.cost, 'Reliability': parent.reliability}"
              },
              "x": {
                "field": "field",
                "scale": "dimScale"
              },
              "y": {
                "signal": "scale('yScore', parent[datum.field])"
              }
            },
            "update": {
              "opacity": [
                {
                  "test": "hovered === null || hovered === parent.name",
                  "value": 0.75
                },
                {
                  "value": 0.05
                }
              ],
              "stroke": {
                "scale": "color",
                "signal": "parent.category"
              }
            }
          },
          "from": {
            "data": "fields"
          },
          "type": "line"
        }
      ],
      "type": "group"
    },
    {
      "encode": {
        "enter": {
          "stroke": {
            "value": "#dee2e6"
          },
          "strokeWidth": {
            "value": 1
          },
          "x": {
            "field": "field",
            "scale": "dimScale"
          },
          "x2": {
            "field": "field",
            "scale": "dimScale"
          },
          "y": {
            "value": 0
          },
          "y2": {
            "signal": "height"
          }
        }
      },
      "from": {
        "data": "fields"
      },
      "type": "rule"
    },
    {
      "encode": {
        "enter": {
          "align": {
            "value": "center"
          },
          "baseline": {
            "value": "bottom"
          },
          "fill": {
            "value": "#495057"
          },
          "fontSize": {
            "value": 12
          },
          "fontWeight": {
            "value": "600"
          },
          "text": {
            "field": "label"
          },
          "x": {
            "field": "field",
            "scale": "dimScale"
          },
          "y": {
            "value": -10
          }
        }
      },
      "from": {
        "data": "fields"
      },
      "type": "text"
    },
    {
      "encode": {
        "enter": {
          "align": {
            "value": "center"
          },
          "baseline": {
            "value": "bottom"
          },
          "fill": {
            "value": "#868e96"
          },
          "fontSize": {
            "value": 10
          },
          "text": {
            "value": "100"
          },
          "x": {
            "field": "field",
            "scale": "dimScale"
          },
          "y": {
            "value": -24
          }
        }
      },
      "from": {
        "data": "fields"
      },
      "type": "text"
    },
    {
      "encode": {
        "enter": {
          "align": {
            "value": "center"
          },
          "baseline": {
            "value": "top"
          },
          "fill": {
            "value": "#868e96"
          },
          "fontSize": {
            "value": 10
          },
          "text": {
            "value": "0"
          },
          "x": {
            "field": "field",
            "scale": "dimScale"
          },
          "y": {
            "signal": "height + 14"
          }
        }
      },
      "from": {
        "data": "fields"
      },
      "type": "text"
    }
  ],
  "padding": {
    "bottom": 16,
    "left": 24,
    "right": 24,
    "top": 16
  },

  "scales": [
    {
      "domain": {
        "data": "fields",
        "field": "field"
      },
      "name": "dimScale",
      "range": "width",
      "type": "point"
    },
    {
      "domain": [
        0,
        100
      ],
      "name": "yScore",
      "nice": true,
      "range": "height",
      "type": "linear",
      "zero": true
    },
    {
      "domain": [
        "Platform A",
        "Platform B",
        "Platform D"
      ],
      "name": "color",
      "range": [
        "#1c7ed6",
        "#0ca678",
        "#e8590c"
      ],
      "type": "ordinal"
    }
  ],

  "signals": [
    {
      "name": "hovered",
      "on": [
        {
          "events": "line:pointerover",
          "update": "datum.name"
        },
        {
          "events": "line:pointerout",
          "update": "null"
        }
      ],
      "value": null
    },
    {
      "name": "fieldCount",
      "update": "length(data('fields'))"
    },
    {
      "name": "axisStep",
      "update": "fieldCount > 1 ? width / (fieldCount - 1) : width"
    }
  ],
  "title": {
    "anchor": "start",
    "fontSize": 16,
    "offset": 16,
    "subtitle": "Multi-variate performance comparison across 15 products by category (scores 0–100)",
    "subtitleColor": "#868e96",
    "subtitleFontSize": 12,
    "text": "Platform B dominates on reliability; Platform D leads in speed"
  },
  "width": 640
}
