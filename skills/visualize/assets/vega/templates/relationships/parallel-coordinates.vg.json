{
  "_metadata": {
    "customization": [
      "Replace 'values' array with your data",
      "Update the 'fields' signal to list your actual dimension field names",
      "Update axis title labels in the 'axes' signal if renaming dimensions",
      "Adjust the color scale domain and range to match your categories",
      "Modify title and description for your context"
    ],
    "dataFormat": "Array of objects with a 'name' (nominal), 'category' (nominal for color grouping), and 5 numeric dimension fields: 'speed', 'efficiency', 'quality', 'cost', 'reliability'"
  },
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "autosize": {
    "contains": "padding",
    "type": "fit"
  },

  "config": {
    "aria": true,
    "axis": {
      "labelFont": "system-ui, -apple-system, sans-serif",
      "titleFont": "system-ui, -apple-system, sans-serif"
    },
    "title": {
      "font": "system-ui, -apple-system, sans-serif"
    }
  },

