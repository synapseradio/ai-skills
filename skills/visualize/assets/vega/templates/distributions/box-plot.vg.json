            "field": "whiskerHigh",
            "scale": "y"
          }
        }
      },
      "from": {
        "data": "stats"
      },
      "type": "rule"
    },
    {
      "description": "IQR box (Q1 to Q3)",
      "encode": {
        "enter": {
          "cornerRadius": {
            "value": 2
          },
          "tooltip": {
            "signal": "{'Class': datum.group, 'Median': datum.median + ' pts', 'Q1': datum.q1 + ' pts', 'Q3': datum.q3 + ' pts', 'Whisker low': datum.whiskerLow + ' pts', 'Whisker high': datum.whiskerHigh + ' pts'}"
          },
          "x": {
            "field": "group",
            "offset": 4,
            "scale": "x"
          },
          "x2": {
            "band": 1,
            "field": "group",
            "offset": -4,
            "scale": "x"
          },
          "y": {
            "field": "q3",
            "scale": "y"
          },
          "y2": {
            "field": "q1",
            "scale": "y"
          }
        },
        "update": {
          "fill": {
            "field": "group",
            "scale": "color"
          },
          "opacity": [
            {
              "test": "hovered === null || hovered.group === datum.group",
              "value": 0.7
            },
            {
              "value": 0.15
            }
          ]
        }
      },
      "from": {
        "data": "stats"
      },
      "type": "rect"
    },
    {
