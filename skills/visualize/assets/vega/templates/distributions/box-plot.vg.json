  "padding": {
    "bottom": 16,
    "left": 24,
    "right": 24,
    "top": 16
  },

  "scales": [
    {
      "domain": {
        "data": "stats",
        "field": "group"
      },
      "name": "x",
      "padding": 0.4,
      "range": "width",
      "type": "band"
    },
    {
      "domain": {
        "data": "source",
        "field": "value"
      },
      "name": "y",
      "nice": true,
      "range": "height",
      "type": "linear",
      "zero": false
    },
    {
      "domain": {
        "data": "stats",
        "field": "group"
      },
      "name": "color",
      "range": [
        "#1c7ed6",
        "#e8590c",
        "#0ca678",
        "#f03e3e"
      ],
      "type": "ordinal"
    }
  ],

  "signals": [
    {
      "name": "hovered",
      "on": [
        {
          "events": "rect:pointerover",
          "update": "datum"
        },
        {
          "events": "rect:pointerout",
          "update": "null"
        }
      ],
      "value": null
    }
  ],
  "title": {
    "anchor": "start",
    "fontSize": 16,
    "offset": 16,
    "subtitle": "Test score distribution by class (points, 0–100)",
    "subtitleColor": "#868e96",
    "subtitleFontSize": 12,
    "text": "Class B scores highest; Class D spans the widest range"
  },
  "width": 600
}
