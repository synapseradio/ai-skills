{
  "_metadata": {
    "customization": [
      "Replace 'values' array with your raw observations",
      "Change 'group' and 'value' field names in transforms, scales, and marks",
      "Update axes titles and units for your variables",
      "Adjust IQR multiplier (1.5) in whisker bound formulas to change fence width",
      "Modify title and description for your context"
    ],
    "dataFormat": "Array of objects with 'group' (nominal category) and 'value' (quantitative measurement) fields. Multiple observations per group -- Vega computes quartiles, whiskers, and outliers from the raw data."
  },
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "autosize": {
    "contains": "padding",
    "type": "fit"
  },
  "axes": [
    {
      "domainColor": "#dee2e6",
      "labelColor": "#868e96",
      "labelFontSize": 12,
      "orient": "bottom",
      "scale": "x",
      "tickColor": "#dee2e6",
      "title": "Class",
      "titleColor": "#495057",
      "titleFontSize": 13
    },
    {
      "domainColor": "#dee2e6",
      "grid": true,
      "gridColor": "#f1f3f5",
      "gridDash": [
        2,
        2
      ],
      "labelColor": "#868e96",
      "labelFontSize": 12,
      "orient": "left",
      "scale": "y",
      "tickColor": "#dee2e6",
      "title": "Test Score (points)",
      "titleColor": "#495057",
      "titleFontSize": 13
    }
  ],
  "config": {
    "aria": true,
    "axis": {
      "labelFont": "system-ui, -apple-system, sans-serif",
      "titleFont": "system-ui, -apple-system, sans-serif"
    },
    "title": {
      "font": "system-ui, -apple-system, sans-serif"
    }
  },
  "data": [
    {
      "name": "source",
      "values": [
        {
          "group": "Class A",
          "value": 65
        },
        {
          "group": "Class A",
          "value": 68
        },
        {
          "group": "Class A",
          "value": 71
        },
        {
          "group": "Class A",
          "value": 74
        },
        {
          "group": "Class A",
          "value": 75
        },
        {
          "group": "Class A",
          "value": 78
        },
        {
          "group": "Class A",
          "value": 82
        },
        {
          "group": "Class A",
          "value": 85
        },
        {
          "group": "Class B",
          "value": 55
        },
        {
          "group": "Class B",
          "value": 62
        },
        {
          "group": "Class B",
          "value": 72
        },
        {
          "group": "Class B",
          "value": 78
        },
        {
          "group": "Class B",
          "value": 84
        },
        {
          "group": "Class B",
          "value": 88
        },
        {
          "group": "Class B",
          "value": 92
        },
        {
          "group": "Class B",
          "value": 95
        },
        {
          "group": "Class C",
          "value": 42
        },
        {
          "group": "Class C",
          "value": 50
        },
        {
          "group": "Class C",
          "value": 55
        },
        {
          "group": "Class C",
          "value": 60
        },
        {
          "group": "Class C",
          "value": 65
        },
        {
          "group": "Class C",
          "value": 68
        },
        {
          "group": "Class C",
          "value": 72
        },
        {
          "group": "Class C",
          "value": 95
        }
      ]
    },
    {
      "name": "stats",
      "source": "source",
      "transform": [
        {
          "as": [
            "q1",
            "median",
            "q3",
            "min",
            "max"
          ],
          "fields": [
            "value",
            "value",
            "value",
            "value",
            "value"
          ],
          "groupby": [
            "group"
          ],
          "ops": [
            "q1",
            "median",
            "q3",
            "min",
            "max"
          ],
          "type": "aggregate"
        },
        {
          "as": "iqr",
          "expr": "datum.q3 - datum.q1",
          "type": "formula"
        },
        {
          "as": "whiskerLow",
          "expr": "max(datum.min, datum.q1 - 1.5 * datum.iqr)",
          "type": "formula"
        },
        {
          "as": "whiskerHigh",
          "expr": "min(datum.max, datum.q3 + 1.5 * datum.iqr)",
          "type": "formula"
        }
      ]
    },
    {
      "name": "outliers",
      "source": "source",
      "transform": [
        {
          "as": [
            "whiskerLow",
            "whiskerHigh"
          ],
          "fields": [
            "group"
          ],
          "from": "stats",
          "key": "group",
          "type": "lookup",
          "values": [
            "whiskerLow",
            "whiskerHigh"
          ]
        },
        {
          "expr": "datum.value < datum.whiskerLow || datum.value > datum.whiskerHigh",
          "type": "filter"
        }
      ]
    }
  ],
  "description": "Box plots comparing score distributions across three classes. Class B has the highest median. Class C contains an outlier at the upper extreme.",
  "height": 400,
  "marks": [
    {
      "from": {
        "data": "stats"
      },
      "marks": [
        {
          "description": "Whisker from lower fence to upper fence",
          "encode": {
            "enter": {
              "stroke": {
                "field": "group",
                "scale": "color"
              },
              "strokeDash": [
                3,
                2
              ],
              "strokeWidth": 1.5,
              "x": {
                "band": 0.5,
                "field": "group",
                "scale": "x"
              },
              "y": {
                "field": "whiskerLow",
                "scale": "y"
              },
              "y2": {
                "field": "whiskerHigh",
                "scale": "y"
              }
            }
          },
          "type": "rule"
        },
        {
          "description": "Lower whisker cap",
          "encode": {
            "enter": {
              "stroke": {
                "field": "group",
                "scale": "color"
              },
              "strokeWidth": 1.5,
              "x": {
                "band": 0.25,
                "field": "group",
                "scale": "x"
              },
              "x2": {
                "band": 0.75,
                "field": "group",
                "scale": "x"
              },
              "y": {
                "field": "whiskerLow",
                "scale": "y"
              },
              "y2": {
                "field": "whiskerLow",
                "scale": "y"
              }
            }
          },
          "type": "rule"
        },
        {
          "description": "Upper whisker cap",
          "encode": {
            "enter": {
              "stroke": {
                "field": "group",
                "scale": "color"
              },
              "strokeWidth": 1.5,
              "x": {
                "band": 0.25,
                "field": "group",
                "scale": "x"
              },
              "x2": {
                "band": 0.75,
                "field": "group",
                "scale": "x"
              },
              "y": {
                "field": "whiskerHigh",
                "scale": "y"
              },
              "y2": {
                "field": "whiskerHigh",
                "scale": "y"
              }
            }
          },
          "type": "rule"
        },
        {
          "description": "IQR box (Q1 to Q3)",
          "encode": {
            "enter": {
              "cornerRadius": 2,
              "tooltip": {
                "signal": "{'Class': datum.group, 'Median': datum.median + ' pts', 'Q1': datum.q1 + ' pts', 'Q3': datum.q3 + ' pts', 'Whisker low': datum.whiskerLow + ' pts', 'Whisker high': datum.whiskerHigh + ' pts'}"
              },
              "x": {
                "field": "group",
                "offset": 4,
                "scale": "x"
              },
              "x2": {
                "band": 1,
                "field": "group",
                "offset": -4,
                "scale": "x"
              },
              "y": {
                "field": "q3",
                "scale": "y"
              },
              "y2": {
                "field": "q1",
                "scale": "y"
              }
            },
            "update": {
              "fill": {
                "field": "group",
                "scale": "color"
              },
              "opacity": [
                {
                  "test": "hovered === null || hovered.group === datum.group",
                  "value": 0.7
                },
                {
                  "value": 0.15
                }
              ]
            }
          },
          "type": "rect"
        },
        {
          "description": "Median line",
          "encode": {
            "enter": {
              "stroke": "#212529",
              "strokeWidth": 2.5,
              "x": {
                "field": "group",
                "offset": 4,
                "scale": "x"
              },
              "x2": {
                "band": 1,
                "field": "group",
                "offset": -4,
                "scale": "x"
              },
              "y": {
                "field": "median",
                "scale": "y"
              },
              "y2": {
                "field": "median",
                "scale": "y"
              }
            }
          },
          "type": "rule"
        }
      ],
      "type": "group"
    },
    {
      "description": "Outlier points",
      "encode": {
        "enter": {
          "fill": "#f03e3e",
          "shape": "circle",
          "size": 40,
          "stroke": "white",
          "strokeWidth": 1,
          "tooltip": {
            "signal": "{'Class': datum.group, 'Outlier': datum.value + ' pts'}"
          },
          "x": {
            "band": 0.5,
            "field": "group",
            "scale": "x"
          },
          "y": {
            "field": "value",
            "scale": "y"
          }
        }
      },
      "from": {
        "data": "outliers"
      },
      "type": "symbol"
    },
    {
      "description": "Jittered sample data points",
      "encode": {
        "enter": {
          "fill": {
            "field": "group",
            "scale": "color"
          },
          "fillOpacity": {
            "value": 0.35
          },
          "shape": "circle",
          "size": 25,
          "tooltip": {
            "signal": "{'Class': datum.group, 'Score': datum.value + ' pts'}"
          },
          "x": {
            "signal": "scale('x', datum.group) + bandwidth('x') * (random() - 0.5) * 0.6"
          },
          "y": {
            "field": "value",
            "scale": "y"
          }
        }
      },
      "from": {
        "data": "source"
      },
      "type": "symbol"
    }
  ],
  "padding": {
    "bottom": 16,
    "left": 24,
    "right": 24,
    "top": 16
  },
  "scales": [
    {
      "domain": {
        "data": "stats",
        "field": "group"
      },
      "name": "x",
      "padding": 0.4,
      "range": "width",
      "type": "band"
    },
    {
      "domain": {
        "data": "source",
        "field": "value"
      },
      "name": "y",
      "nice": true,
      "range": "height",
      "type": "linear",
      "zero": false
    },
    {
      "domain": {
        "data": "stats",
        "field": "group"
      },
      "name": "color",
      "range": [
        "#1c7ed6",
        "#e8590c",
        "#0ca678"
      ],
      "type": "ordinal"
    }
  ],
  "signals": [
    {
      "name": "hovered",
      "on": [
        {
          "events": "rect:pointerover",
          "update": "datum"
        },
        {
          "events": "rect:pointerout",
          "update": "null"
        }
      ],
      "value": null
    }
  ],
  "title": {
    "anchor": "start",
    "fontSize": 16,
    "offset": 16,
    "subtitle": "Test score distribution by class (points, 0–100)",
    "subtitleColor": "#868e96",
    "subtitleFontSize": 12,
    "text": "Class B scores highest; Class C has the widest spread"
  },
  "width": 600
}
