    {
      "name": "stats",
      "source": "source",
      "transform": [
        {
          "as": [
            "q1",
            "median",
            "q3",
            "min",
            "max"
          ],
          "fields": [
            "value",
            "value",
            "value",
            "value",
            "value"
          ],
          "groupby": [
            "group"
          ],
          "ops": [
            "q1",
            "median",
            "q3",
            "min",
            "max"
          ],
          "type": "aggregate"
        },
        {
          "as": "iqr",
          "expr": "datum.q3 - datum.q1",
          "type": "formula"
        },
        {
          "as": "whiskerLow",
          "expr": "max(datum.min, datum.q1 - 1.5 * datum.iqr)",
          "type": "formula"
        },
        {
          "as": "whiskerHigh",
          "expr": "min(datum.max, datum.q3 + 1.5 * datum.iqr)",
          "type": "formula"
        }
      ]
    },
    {
      "name": "outliers",
      "source": "source",
      "transform": [
        {
          "as": [
            "whiskerLow",
            "whiskerHigh"
          ],
          "fields": [
            "group"
          ],
          "from": "stats",
          "key": "group",
          "type": "lookup",
          "values": [
            "whiskerLow",
            "whiskerHigh"
          ]
        },
        {
          "expr": "datum.value < datum.whiskerLow || datum.value > datum.whiskerHigh",
          "type": "filter"
        }
      ]
    }
  ],
  "description": "Box plots comparing score distributions across four classes. Class B has the highest median (84 points), while Class D shows the widest spread. Class C contains outliers at both extremes.",
  "height": 400,

  "marks": [
    {
      "description": "Whisker: lower fence to Q1",
      "encode": {
        "enter": {
          "stroke": {
            "field": "group",
            "scale": "color"
          },
          "strokeDash": {
            "value": [
              3,
              2
            ]
          },
          "strokeWidth": {
            "value": 1.5
          },
          "x": {
            "band": 0.5,
            "field": "group",
            "scale": "x"
          },
          "y": {
            "field": "whiskerLow",
            "scale": "y"
          },
          "y2": {
            "field": "q1",
            "scale": "y"
          }
        }
      },
      "from": {
        "data": "stats"
      },
      "type": "rule"
    },
    {
      "description": "Whisker: Q3 to upper fence",
      "encode": {
        "enter": {
          "stroke": {
            "field": "group",
            "scale": "color"
