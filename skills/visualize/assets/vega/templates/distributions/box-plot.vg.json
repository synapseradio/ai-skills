            "signal": "{'Class': datum.group, 'Outlier': datum.value + ' pts'}"
          },
          "x": {
            "band": 0.5,
            "field": "group",
            "scale": "x"
          },
          "y": {
            "field": "value",
            "scale": "y"
          }
        }
      },
      "from": {
        "data": "outliers"
      },
      "type": "symbol"
    }
