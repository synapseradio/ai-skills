    {
      "name": "density",
      "source": "table",
      "transform": [
        {
          "type": "kde",
          "field": "value",
          "groupby": [
            "group"
          ],
          "bandwidth": {
            "signal": "bandwidth"
          },
          "extent": [
            40,
            100
          ]
        }
      ]
    },
    {
      "name": "stats",
      "source": "table",
      "transform": [
        {
          "type": "aggregate",
          "groupby": [
            "group"
          ],
          "fields": [
            "value",
            "value",
            "value"
          ],
          "ops": [
            "q1",
            "median",
            "q3"
          ],
          "as": [
            "q1",
            "median",
            "q3"
          ]
        }
      ]
    }
  ],
  "scales": [
    {
      "name": "layout",
      "type": "band",
      "range": "width",
      "domain": {
        "data": "table",
        "field": "group"
      }
    },
    {
      "name": "yscale",
      "type": "linear",
      "range": "height",
      "round": true,
      "domain": {
        "data": "table",
        "field": "value"
      },
      "domainMin": 40,
      "domainMax": 100,
      "zero": false,
      "nice": true
    },
    {
      "name": "hscale",
      "type": "linear",
      "range": [
        0,
        {
          "signal": "plotWidth"
        }
      ],
      "domain": {
        "data": "density",
        "field": "density"
      }
    },
    {
      "name": "color",
      "type": "ordinal",
      "domain": {
        "data": "table",
        "field": "group"
      },
      "range": {
        "scheme": "tableau10"
      }
    }
  ],
  "axes": [
    {
      "orient": "bottom",
      "scale": "layout",
      "zindex": 1,
      "title": "Class"
    },
    {
      "orient": "left",
      "scale": "yscale",
      "zindex": 1,
      "title": "Test Score"
    }
  ],
  "marks": [
    {
      "type": "group",
      "from": {
        "facet": {
          "data": "density",
          "name": "violin",
          "groupby": "group"
        }
      },
      "encode": {
        "enter": {
          "xc": {
            "scale": "layout",
            "field": "group",
            "band": 0.5
          },
          "width": {
            "signal": "plotWidth"
          },
          "height": {
            "signal": "height"
          }
        }
      },
      "data": [
        {
          "name": "summary",
          "source": "stats",
          "transform": [
            {
              "type": "filter",
              "expr": "datum.group === parent.group"
            }
          ]
        }
      ],
      "marks": [
        {
          "type": "area",
          "from": {
            "data": "violin"
          },
          "encode": {
            "enter": {
              "fill": {
                "scale": "color",
                "field": {
                  "parent": "group"
                }
              },
              "fillOpacity": {
                "value": 0.7
              },
              "stroke": {
                "scale": "color",
                "field": {
                  "parent": "group"
                }
              },
              "strokeWidth": {
                "value": 1.5
              },
              "tooltip": {
                "signal": "{'Group': parent.group, 'Score': format(datum.value, '.1f'), 'Density': format(datum.density, '.4f')}"
              }
            },
            "update": {
              "xc": {
                "signal": "plotWidth / 2"
              },
              "width": {
                "scale": "hscale",
                "field": "density"
              },
              "y": {
                "scale": "yscale",
                "field": "value"
              }
            }
          }
        },
        {
          "type": "rect",
          "from": {
            "data": "summary"
          },
          "encode": {
            "enter": {
              "fill": {
                "value": "white"
              },
              "fillOpacity": {
                "value": 0.9
              },
              "stroke": {
                "value": "#333"
              },
              "strokeWidth": {
                "value": 1
              },
              "width": {
                "value": 8
              },
              "cornerRadius": {
                "value": 2
              }
            },
            "update": {
              "xc": {
                "signal": "plotWidth / 2"
              },
              "y": {
                "scale": "yscale",
                "field": "q3"
              },
              "y2": {
                "scale": "yscale",
                "field": "q1"
              }
            }
          }
        },
        {
          "type": "symbol",
          "from": {
            "data": "summary"
          },
          "encode": {
            "enter": {
              "fill": {
                "value": "#333"
              },
              "size": {
                "value": 30
              },
              "shape": {
                "value": "circle"
              },
              "tooltip": {
                "signal": "{'Median': format(datum.median, '.1f'), 'Q1': format(datum.q1, '.1f'), 'Q3': format(datum.q3, '.1f')}"
              }
            },
            "update": {
              "x": {
                "signal": "plotWidth / 2"
              },
              "y": {
                "scale": "yscale",
                "field": "median"
              }
            }
          }
        }
      ]
    }
  ],
  "title": {
    "text": "Test Score Distribution by Class",
    "subtitle": "Violin plots revealing distribution shapes -- wider sections indicate more common values"
  }
}
