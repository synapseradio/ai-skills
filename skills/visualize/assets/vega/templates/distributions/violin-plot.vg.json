  "description": "Violin plot comparing distribution shapes across three classes. Class A is approximately normal, Class B is left-skewed, Class C is bimodal (two distinct peaks suggesting subpopulations).",
  "height": 400,
  "marks": [
    {
      "data": [
        {
          "name": "summary",
          "source": "stats",
          "transform": [
            {
              "expr": "datum.group === parent.group",
              "type": "filter"
            }
          ]
        }
      ],
      "encode": {
        "enter": {
          "height": {
            "signal": "height"
          },
          "width": {
            "signal": "plotWidth"
          },
          "xc": {
            "band": 0.5,
            "field": "group",
            "scale": "layout"
          }
        }
      },
      "from": {
        "facet": {
          "data": "density",
          "groupby": "group",
          "name": "violin"
        }
      },
      "marks": [
        {
          "encode": {
            "enter": {
              "fill": {
                "field": {
                  "parent": "group"
                },
                "scale": "color"
              },
              "fillOpacity": 0.7,
              "stroke": {
                "field": {
                  "parent": "group"
                },
                "scale": "color"
              },
              "strokeWidth": 1.5,
              "tooltip": {
                "signal": "{'Group': parent.group, 'Score': format(datum.value, '.1f'), 'Density': format(datum.density, '.4f')}"
              }
            },
            "update": {
              "width": {
                "field": "density",
                "scale": "hscale"
              },
              "xc": {
                "signal": "plotWidth / 2"
              },
              "y": {
                "field": "value",
                "scale": "yscale"
              }
            }
          },
          "from": {
            "data": "violin"
          },
          "type": "area"
        },
        {
          "encode": {
            "enter": {
              "cornerRadius": 2,
              "fill": "white",
              "fillOpacity": 0.9,
              "stroke": "#333",
              "strokeWidth": 1,
              "width": {
                "value": 8
              }
            },
            "update": {
              "xc": {
                "signal": "plotWidth / 2"
              },
              "y": {
                "field": "q3",
                "scale": "yscale"
              },
              "y2": {
                "field": "q1",
                "scale": "yscale"
              }
            }
          },
          "from": {
            "data": "summary"
          },
          "type": "rect"
        },
        {
          "encode": {
            "enter": {
              "fill": "#333",
              "shape": "circle",
              "size": 30,
              "tooltip": {
                "signal": "{'Median': format(datum.median, '.1f'), 'Q1': format(datum.q1, '.1f'), 'Q3': format(datum.q3, '.1f')}"
              }
            },
            "update": {
              "x": {
                "signal": "plotWidth / 2"
              },
              "y": {
                "field": "median",
                "scale": "yscale"
              }
            }
          },
          "from": {
            "data": "summary"
          },
          "type": "symbol"
        }
      ],
      "type": "group"
    }
  ],
  "padding": {
    "bottom": 16,
    "left": 24,
    "right": 24,
    "top": 16
  },
  "scales": [
    {
      "domain": {
        "data": "table",
        "field": "group"
      },
      "name": "layout",
      "range": "width",
      "type": "band"
    },
    {
      "domain": {
        "data": "table",
        "field": "value"
      },
      "domainMax": 100,
      "domainMin": 40,
      "name": "yscale",
      "nice": true,
      "range": "height",
      "round": true,
      "type": "linear",
      "zero": false
    },
    {
      "domain": {
        "data": "density",
        "field": "density"
      },
      "name": "hscale",
      "range": [
        0,
        {
          "signal": "plotWidth"
        }
      ],
      "type": "linear"
    },
    {
      "domain": {
        "data": "table",
        "field": "group"
      },
      "name": "color",
      "range": [
        "#1c7ed6",
        "#e8590c",
        "#0ca678"
      ],
      "type": "ordinal"
    }
  ],
  "signals": [
    {
      "name": "plotWidth",
      "value": 60
    }
  ],
  "title": {
    "anchor": "start",
    "fontSize": 16,
    "offset": 16,
    "subtitle": "Test score distribution by class; wider = more common values (points, 0–100)",
    "subtitleColor": "#868e96",
    "subtitleFontSize": 12,
    "text": "Class C shows a bimodal split — two distinct score clusters emerge"
  },
  "width": 500
}
