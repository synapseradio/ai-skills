{
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "_metadata": {
    "dataFormat": "Array of objects with 'group' (nominal category) and 'value' (quantitative measurement) fields. Multiple observations per group -- KDE transform computes the density curve.",
    "customization": [
      "Replace 'values' array in data[0] with your raw observations",
      "Change 'group' and 'value' field names in data transforms, scales, and marks",
      "Adjust the KDE extent (data[1].transform[0].extent) to match your data range",
      "Adjust scales yscale domainMin/domainMax to match your data range",
      "Update axes titles for your variable names",
      "Modify title.text and title.subtitle for your context"
    ],
    "notes": "The bandwidth signal defaults to 0 (auto-detect). The interactive range slider lets users adjust KDE smoothing."
  },
  "description": "Violin plot comparing distribution shapes across four classes. Class A is approximately normal, Class B is left-skewed, Class C is bimodal (two distinct peaks suggesting subpopulations), and Class D is roughly uniform.",
