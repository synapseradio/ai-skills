      "scale": "x",
      "tickColor": "#dee2e6",
      "title": "Test Score (points)",
      "titleColor": "#495057",
      "titleFontSize": 13
    },
    {
      "domainColor": "#dee2e6",
      "grid": true,
      "gridColor": "#f1f3f5",
      "gridDash": [
        2,
        2
      ],
      "labelColor": "#868e96",
      "labelFontSize": 12,
      "orient": "left",
      "scale": "y",
      "tickColor": "#dee2e6",
      "title": "Frequency (students)",
      "titleColor": "#495057",
      "titleFontSize": 13
    }
  ],

