    "customization": [
      "Replace 'values' array with your observations",
      "Change field name in the bin transform 'field' property and in marks",
      "Adjust the bin transform 'maxbins' to control bin count",
      "Update axes titles and units for your variable",
      "Modify title and description for your context"
    ],
    "dataFormat": "Array of objects with a single 'value' (quantitative) field. Each object is one observation."
  },
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "autosize": {
    "contains": "padding",
    "type": "fit"
