  "description": "Histogram showing the frequency distribution of test scores. The distribution is approximately normal, clustering between 70 and 85 points, with the bulk of observations in that range. Tails extend down to 45 and up to 98.",
  "height": 400,

  "marks": [
    {
      "encode": {
        "enter": {
          "cornerRadiusTopLeft": {
            "value": 2
          },
          "cornerRadiusTopRight": {
            "value": 2
          },
          "tooltip": {
            "signal": "{'Score range': format(datum.bin0, '.0f') + '–' + format(datum.bin1, '.0f') + ' pts', 'Students': datum.count}"
          },
          "x": {
            "field": "bin0",
            "offset": 1,
            "scale": "x"
          },
          "x2": {
            "field": "bin1",
            "offset": -1,
            "scale": "x"
          },
          "y": {
            "field": "count",
            "scale": "y"
          },
          "y2": {
            "scale": "y",
            "value": 0
          }
        },
        "update": {
          "fill": {
            "field": "bin0",
            "scale": "color"
          },
          "opacity": [
            {
              "test": "hovered === null || hovered.bin0 === datum.bin0",
              "value": 1
            },
            {
              "value": 0.3
            }
          ]
        }
      },
      "from": {
        "data": "bins"
      },
      "type": "rect"
    }
  ],
  "padding": {
    "bottom": 16,
    "left": 24,
    "right": 24,
    "top": 16
  },

  "scales": [
    {
      "domain": [
        40,
        100
      ],
      "name": "x",
      "range": "width",
      "type": "linear",
      "zero": false
    },
    {
      "domain": {
        "data": "bins",
        "field": "count"
      },
      "name": "y",
      "nice": true,
      "range": "height",
      "type": "linear",
      "zero": true
    },
    {
      "domain": {
        "data": "bins",
        "field": "bin0"
      },
      "name": "color",
      "range": [
        "#74b816",
        "#1c7ed6"
      ],
      "type": "linear"
    }
  ],

  "signals": [
    {
      "name": "hovered",
      "on": [
        {
          "events": "rect:pointerover",
          "update": "datum"
        },
        {
          "events": "rect:pointerout",
          "update": "null"
        }
      ],
      "value": null
    }
  ],
  "title": {
    "anchor": "start",
    "fontSize": 16,
    "offset": 16,
    "subtitle": "Distribution of test scores (points, 0–100)",
    "subtitleColor": "#868e96",
    "subtitleFontSize": 12,
    "text": "Scores cluster tightly between 70 and 85"
  },
  "width": 600
}
