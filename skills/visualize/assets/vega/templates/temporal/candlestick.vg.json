{
  "_metadata": {
    "customization": [
      "Replace 'values' array with your OHLC data",
      "Change field names in scales, axes, and marks to match your data",
      "Adjust bullish/bearish colors in the rule and rect marks (default: green #0ca678 / red #f03e3e)",
      "Change 'bandWidth' signal value to adjust candle body thickness",
      "Modify title and description for your context"
    ],
    "dataFormat": "Array of objects with 'date' (ISO 8601 date string), 'open' (quantitative), 'high' (quantitative), 'low' (quantitative), and 'close' (quantitative) fields. One object per trading period.",
    "notes": "Two mark layers: rule marks draw the high-low wick, rect marks draw the open-close body. A 'bullish' formula field drives conditional fill. Hover highlights the active candle."
  },
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "autosize": {
    "contains": "padding",
    "type": "fit"
  },

  "axes": [
    {
      "domainColor": "#dee2e6",
      "format": "%b %d",
      "grid": true,
      "gridColor": "#f1f3f5",
      "gridDash": [
        2,
        2
      ],
      "labelAlign": "right",
      "labelAngle": -45,
      "labelColor": "#868e96",
      "labelFontSize": 12,
      "orient": "bottom",
      "scale": "x",
      "tickColor": "#dee2e6",
      "title": "Date",
      "titleColor": "#495057",
      "titleFontSize": 13
    },
    {
      "domainColor": "#dee2e6",
      "format": "$,.2f",
      "grid": true,
      "gridColor": "#f1f3f5",
      "gridDash": [
        2,
        2
      ],
      "labelColor": "#868e96",
      "labelFontSize": 12,
      "orient": "left",
      "scale": "y",
      "tickColor": "#dee2e6",
      "title": "Price (USD)",
      "titleColor": "#495057",
      "titleFontSize": 13
    }
  ],

  "config": {
    "aria": true,
    "axis": {
      "labelFont": "system-ui, -apple-system, sans-serif",
      "titleFont": "system-ui, -apple-system, sans-serif"
    },
    "title": {
      "font": "system-ui, -apple-system, sans-serif"
    }
  },

  "data": [
    {
      "name": "source",
      "transform": [
        {
          "as": "dateVal",
          "expr": "toDate(datum.date)",
          "type": "formula"
        },
        {
          "as": "bullish",
          "expr": "datum.open <= datum.close",
          "type": "formula"
        },
        {
          "as": "bodyHigh",
          "expr": "max(datum.open, datum.close)",
          "type": "formula"
        },
        {
          "as": "bodyLow",
          "expr": "min(datum.open, datum.close)",
          "type": "formula"
        }
      ],
      "values": [
        {
          "close": 144.8,
          "date": "2024-11-01",
          "high": 145.2,
          "low": 141.3,
          "open": 142.5
        },
        {
          "close": 145.2,
          "date": "2024-11-04",
          "high": 146.5,
          "low": 143.8,
          "open": 144.9
        },
        {
          "close": 147.3,
          "date": "2024-11-05",
          "high": 147.8,
          "low": 144.5,
          "open": 145.0
        },
        {
          "close": 148.9,
          "date": "2024-11-06",
          "high": 149.2,
          "low": 146.8,
          "open": 147.5
        },
        {
          "close": 147.8,
          "date": "2024-11-07",
          "high": 150.5,
          "low": 147.2,
          "open": 149.0
        },
        {
          "close": 146.2,
          "date": "2024-11-08",
          "high": 148.9,
          "low": 145.3,
          "open": 147.6
        },
        {
          "close": 145.6,
          "date": "2024-11-11",
          "high": 147.5,
          "low": 144.8,
          "open": 146.0
        },
        {
          "close": 147.9,
          "date": "2024-11-12",
          "high": 148.2,
          "low": 145.2,
          "open": 145.8
        },
        {
          "close": 150.8,
          "date": "2024-11-13",
          "high": 151.3,
          "low": 147.5,
          "open": 148.0
        },
        {
          "close": 152.5,
          "date": "2024-11-14",
          "high": 153.2,
          "low": 150.2,
          "open": 151.0
        }
      ]
    }
  ],
  "description": "Candlestick chart showing daily OHLC price movements for ACME Corp over 10 trading days. Stock gained 7% from $142.50 to $152.50. Green candles (close > open) dominate: 7 bullish vs. 3 bearish days.",
  "height": 400,

  "marks": [
    {
      "encode": {
        "enter": {
          "strokeWidth": {
            "value": 1.5
          },
          "x": {
            "field": "dateVal",
            "scale": "x"
          },
          "y": {
            "field": "low",
            "scale": "y"
          },
          "y2": {
            "field": "high",
            "scale": "y"
          }
        },
        "update": {
          "opacity": [
            {
              "test": "hovered === null || hovered.date === datum.date",
              "value": 1
            },
            {
              "value": 0.25
            }
          ],
          "stroke": [
            {
              "test": "datum.bullish",
              "value": "#0ca678"
            },
            {
              "value": "#f03e3e"
            }
          ]
        }
      },
      "from": {
        "data": "source"
      },
      "type": "rule"
    },
    {
      "encode": {
        "enter": {
          "cornerRadiusBottomLeft": {
            "value": 1
          },
          "cornerRadiusBottomRight": {
            "value": 1
          },
          "cornerRadiusTopLeft": {
            "value": 1
          },
          "cornerRadiusTopRight": {
            "value": 1
          },
          "tooltip": {
            "signal": "{'Date': timeFormat(datum.dateVal, '%B %d, %Y'), 'Open ($)': '$' + format(datum.open, ',.2f'), 'High ($)': '$' + format(datum.high, ',.2f'), 'Low ($)': '$' + format(datum.low, ',.2f'), 'Close ($)': '$' + format(datum.close, ',.2f')}"
          },
          "width": {
            "signal": "bandWidth"
          },
          "x": {
            "signal": "scale('x', datum.dateVal) - bandWidth / 2"
          },
          "y": {
            "field": "bodyHigh",
            "scale": "y"
          },
          "y2": {
            "field": "bodyLow",
            "scale": "y"
          }
        },
        "update": {
          "fill": [
            {
              "test": "datum.bullish",
              "value": "#0ca678"
            },
            {
              "value": "#f03e3e"
            }
          ],
          "opacity": [
            {
              "test": "hovered === null || hovered.date === datum.date",
              "value": 1
            },
            {
              "value": 0.25
            }
          ]
        }
      },
      "from": {
        "data": "source"
      },
      "type": "rect"
    }
  ],
  "padding": {
    "bottom": 16,
    "left": 24,
    "right": 24,
    "top": 16
  },

  "scales": [
    {
      "domain": {
        "data": "source",
        "field": "dateVal"
      },
      "name": "x",
      "padding": 0.1,
      "range": "width",
      "type": "time"
    },
    {
      "domain": {
        "data": "source",
        "fields": [
          "low",
          "high"
        ]
      },
      "name": "y",
      "nice": true,
      "range": "height",
      "type": "linear",
      "zero": false
    }
  ],

  "signals": [
    {
      "name": "bandWidth",
      "value": 10
    },
    {
      "name": "hovered",
      "on": [
        {
          "events": "rect:pointerover",
          "update": "datum"
        },
        {
          "events": "rect:pointerout",
          "update": "null"
        }
      ],
      "value": null
    }
  ],
  "title": {
    "anchor": "start",
    "fontSize": 16,
    "offset": 16,
    "subtitle": "ACME Corp daily OHLC price, Nov 1–14 2024 (USD)",
    "subtitleColor": "#868e96",
    "subtitleFontSize": 12,
    "text": "ACME rallied 7% over 10 days, closing above $152"
  },
  "width": 600
}
