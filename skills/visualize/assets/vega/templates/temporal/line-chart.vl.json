{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "_metadata": {
    "dataFormat": "Array of objects with 'date' (temporal ISO 8601 string) and 'value' (quantitative) fields. Null values create gaps in the line.",
    "customization": [
      "Replace 'values' array with your time series data",
      "Change field names in encoding.x.field and encoding.y.field",
      "Adjust encoding.x.axis.format for date display (e.g., '%Y-%m-%d', '%b %Y')",
      "Adjust encoding.y.axis.title and encoding.y.axis.format for your units",
      "Add an encoding.color channel with a 'series' field for multi-line charts",
      "Change mark.interpolate ('monotone', 'linear', 'step') for different curve styles",
      "Set mark.point to false to remove data point markers",
      "Modify title and description for your context"
    ],
    "notes": "Includes a null value in June to demonstrate gap handling. Set mark.point to true (default) to show individual data points."
  },
  "title": "Monthly Revenue Trend",
  "description": "Revenue trend over 12 months showing growth trajectory. Line chart with data point markers for individual value inspection.",
  "width": "container",
  "height": 400,
  "data": {
    "values": [
      {
        "date": "2024-01-01",
        "value": 45000
      },
      {
        "date": "2024-02-01",
        "value": 52000
      },
      {
        "date": "2024-03-01",
        "value": 48000
      },
      {
        "date": "2024-04-01",
        "value": 61000
      },
      {
        "date": "2024-05-01",
        "value": 58000
      },
      {
        "date": "2024-06-01",
        "value": null
      },
      {
        "date": "2024-07-01",
        "value": 71000
      },
      {
        "date": "2024-08-01",
        "value": 68000
      },
      {
        "date": "2024-09-01",
        "value": 79000
      },
      {
        "date": "2024-10-01",
        "value": 82000
      },
      {
        "date": "2024-11-01",
        "value": 85000
      },
      {
        "date": "2024-12-01",
        "value": 89000
      }
    ]
  },
  "mark": {
    "type": "line",
    "point": true,
    "tooltip": true,
    "interpolate": "monotone",
    "color": "#2563eb"
  },
  "encoding": {
    "x": {
      "field": "date",
      "type": "temporal",
      "title": "Month (2024)",
      "axis": {
        "format": "%b",
        "tickCount": "month",
        "grid": true,
        "gridDash": [
          2,
          2
        ],
        "gridColor": "#e5e7eb"
      }
    },
    "y": {
      "field": "value",
      "type": "quantitative",
      "title": "Revenue (USD)",
      "scale": {
        "zero": false
      },
      "axis": {
        "format": "$,.0f",
        "grid": true,
        "gridDash": [
          2,
          2
        ],
        "gridColor": "#e5e7eb"
      }
    }
  },
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelColor": "#6b7280",
      "titleColor": "#374151",
      "tickColor": "#d1d5db",
      "domainColor": "#d1d5db"
    }
  }
}
