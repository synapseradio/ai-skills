{
  "_metadata": {
    "customization": [
      "Replace 'values' array with your data",
      "Change 'metric' field values to your metric names",
      "Update title and subtitle to match your context and units",
      "Adjust 'rowHeight' signal to control vertical spacing",
      "Add or remove metrics -- group marks stack automatically"
    ],
    "dataFormat": "Array of objects with 'metric' (nominal), 'month' (ordinal 1-12), and 'value' (quantitative) fields. All metrics share a scale; normalize values to the same unit for meaningful comparison."
  },
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "autosize": {
    "contains": "padding",
    "type": "fit"
  },
  "config": {
    "aria": true,
    "axis": {
      "labelFont": "system-ui, -apple-system, sans-serif",
      "titleFont": "system-ui, -apple-system, sans-serif"
    },
    "title": {
      "font": "system-ui, -apple-system, sans-serif"
    }
  },
  "data": [
    {
      "name": "source",
      "values": [
        {
          "metric": "Revenue",
          "month": 1,
          "value": 100
        },
        {
          "metric": "Revenue",
          "month": 2,
          "value": 104
        },
        {
          "metric": "Revenue",
          "month": 3,
          "value": 108
        },
        {
          "metric": "Revenue",
          "month": 4,
          "value": 110
        },
        {
          "metric": "Revenue",
          "month": 5,
          "value": 115
        },
        {
          "metric": "Revenue",
          "month": 6,
          "value": 119
        },
        {
          "metric": "Operating Costs",
          "month": 1,
          "value": 100
        },
        {
          "metric": "Operating Costs",
          "month": 2,
          "value": 101
        },
        {
          "metric": "Operating Costs",
          "month": 3,
          "value": 100
        },
        {
          "metric": "Operating Costs",
          "month": 4,
          "value": 102
        },
        {
          "metric": "Operating Costs",
          "month": 5,
          "value": 101
        },
        {
          "metric": "Operating Costs",
          "month": 6,
          "value": 103
        },
        {
          "metric": "Headcount",
          "month": 1,
          "value": 100
        },
        {
          "metric": "Headcount",
          "month": 2,
          "value": 100
        },
        {
          "metric": "Headcount",
          "month": 3,
          "value": 101
        },
        {
          "metric": "Headcount",
          "month": 4,
          "value": 101
        },
        {
          "metric": "Headcount",
          "month": 5,
          "value": 101
        },
        {
          "metric": "Headcount",
          "month": 6,
          "value": 102
        }
      ]
    },
    {
      "name": "metrics",
      "source": "source",
      "transform": [
        {
          "groupby": [
            "metric"
          ],
          "type": "aggregate"
        }
      ]
    }
  ],
  "description": "Sparkline panel showing three monthly metrics, Jan–Jun 2024. Revenue grew from 100 to 119 (index). Operating costs and headcount held steady.",
  "height": 240,
  "marks": [
    {
      "encode": {
        "enter": {
          "clip": true,
          "height": {
            "signal": "rowHeight - 20"
          },
          "width": {
            "signal": "sparklineWidth"
          },
          "x": {
            "signal": "labelWidth + 16"
          },
          "y": {
            "field": "metric",
            "scale": "y_facet"
          }
        }
      },
      "from": {
        "facet": {
          "data": "source",
          "groupby": "metric",
          "name": "faceted"
        }
      },
      "marks": [
        {
          "encode": {
            "enter": {
              "interpolate": "monotone",
              "strokeWidth": 2,
              "x": {
                "field": "month",
                "scale": "x"
              },
              "y": {
                "field": "value",
                "scale": "y_local"
              }
            },
            "update": {
              "opacity": [
                {
                  "test": "hovered === null || hovered.metric === datum.metric",
                  "value": 1
                },
                {
                  "value": 0.25
                }
              ],
              "stroke": {
                "field": "metric",
                "scale": "color"
              }
            }
          },
          "from": {
            "data": "faceted"
          },
          "sort": {
            "field": "month"
          },
          "type": "line"
        },
        {
          "encode": {
            "enter": {
              "shape": "circle",
              "size": 30,
              "x": {
                "field": "month",
                "scale": "x"
              },
              "y": {
                "field": "value",
                "scale": "y_local"
              }
            },
            "update": {
              "fill": {
                "field": "metric",
                "scale": "color"
              },
              "opacity": [
                {
                  "test": "hovered === null || hovered.metric === datum.metric",
                  "value": 1
                },
                {
                  "value": 0.25
                }
              ]
            }
          },
          "from": {
            "data": "faceted"
          },
          "transform": [
            {
              "expr": "datum.month === 6",
              "type": "filter"
            }
          ],
          "type": "symbol"
        }
      ],
      "scales": [
        {
          "domain": {
            "data": "faceted",
            "field": "value"
          },
          "name": "y_local",
          "nice": false,
          "range": [
            {
              "signal": "rowHeight - 28"
            },
            4
          ],
          "type": "linear",
          "zero": false
        }
      ],
      "type": "group"
    },
    {
      "encode": {
        "enter": {
          "align": "right",
          "baseline": "top",
          "fill": {
            "field": "metric",
            "scale": "color"
          },
          "fontSize": 12,
          "fontWeight": 600,
          "text": {
            "field": "metric"
          },
          "x": {
            "signal": "labelWidth + 8"
          },
          "y": {
            "field": "metric",
            "offset": 10,
            "scale": "y_facet"
          }
        }
      },
      "from": {
        "data": "metrics"
      },
      "type": "text"
    }
  ],
  "padding": {
    "bottom": 16,
    "left": 24,
    "right": 24,
    "top": 16
  },
  "scales": [
    {
      "domain": [
        "Revenue",
        "Operating Costs",
        "Headcount"
      ],
      "name": "y_facet",
      "range": [
        0,
        60,
        120
      ],
      "type": "ordinal"
    },
    {
      "domain": [
        "Revenue",
        "Operating Costs",
        "Headcount"
      ],
      "name": "color",
      "range": [
        "#1c7ed6",
        "#e8590c",
        "#0ca678"
      ],
      "type": "ordinal"
    },
    {
      "domain": [
        1,
        6
      ],
      "name": "x",
      "range": [
        0,
        360
      ],
      "type": "linear"
    }
  ],
  "signals": [
    {
      "name": "rowHeight",
      "value": 60
    },
    {
      "name": "sparklineWidth",
      "value": 360
    },
    {
      "name": "labelWidth",
      "value": 110
    },
    {
      "name": "hovered",
      "on": [
        {
          "events": "path:pointerover",
          "update": "datum"
        },
        {
          "events": "path:pointerout",
          "update": "null"
        }
      ],
      "value": null
    }
  ],
  "title": {
    "anchor": "start",
    "fontSize": 16,
    "offset": 16,
    "subtitle": "Monthly KPIs Jan–Jun 2024 (indexed to Jan = 100)",
    "subtitleColor": "#868e96",
    "subtitleFontSize": 12,
    "text": "Revenue up 19%, costs and headcount steady through H1"
  },
  "width": 600
}
