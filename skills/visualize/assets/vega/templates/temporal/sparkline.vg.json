        {
          "metric": "Headcount",
          "month": 12,
          "value": 102
        }
      ]
    },
    {
      "name": "first_values",
      "source": "source",
      "transform": [
        {
          "expr": "datum.month === 1",
          "type": "filter"
        }
      ]
    },
    {
      "name": "last_values",
      "source": "source",
      "transform": [
        {
          "expr": "datum.month === 12",
          "type": "filter"
        }
      ]
    },
    {
      "name": "metrics",
      "source": "source",
      "transform": [
        {
          "groupby": [
            "metric"
          ],
          "type": "aggregate"
        }
      ]
    }
  ],
  "description": "Sparkline panel showing three monthly metrics for 2024. Revenue grew from 100 to 134 (index). Operating costs remained flat around 100–105. Headcount held at 100–102.",
  "height": 420,

  "marks": [
    {
      "encode": {
        "enter": {
          "clip": {
            "value": true
          },
          "height": {
            "signal": "rowHeight - 20"
          },
          "width": {
            "signal": "sparklineWidth"
          },
          "x": {
            "signal": "labelWidth + 16"
          },
          "y": {
            "field": "metric",
            "scale": "y_facet"
          }
        }
      },
      "from": {
        "facet": {
          "data": "source",
          "groupby": "metric",
          "name": "faceted"
        }
      },
      "marks": [
        {
          "encode": {
            "enter": {
              "interpolate": {
                "value": "monotone"
              },
              "strokeWidth": {
                "value": 2
              },
              "x": {
                "field": "month",
                "scale": "x"
              },
              "y": {
                "field": "value",
                "scale": "y_local"
              }
            },
            "update": {
              "opacity": [
                {
                  "test": "hovered === null || hovered.metric === datum.metric",
                  "value": 1
                },
                {
                  "value": 0.25
                }
              ],
              "stroke": {
                "field": "metric",
                "scale": "color"
              }
            }
          },
          "from": {
            "data": "faceted"
          },
          "sort": {
            "field": "month"
          },
          "type": "line"
        },
        {
          "encode": {
            "enter": {
              "shape": {
                "value": "circle"
              },
              "size": {
                "value": 30
              },
              "x": {
                "field": "month",
                "scale": "x"
              },
              "y": {
                "field": "value",
                "scale": "y_local"
              }
            },
            "update": {
              "fill": {
                "field": "metric",
                "scale": "color"
              },
              "opacity": [
                {
                  "test": "hovered === null || hovered.metric === datum.metric",
                  "value": 1
                },
                {
                  "value": 0.25
                }
              ]
            }
          },
          "from": {
            "data": "faceted"
          },
          "transform": [
            {
              "expr": "datum.month === 1 || datum.month === 12",
              "type": "filter"
            }
          ],
          "type": "symbol"
        },
        {
          "encode": {
            "enter": {
              "align": {
                "value": "right"
              },
              "baseline": {
                "value": "middle"
              },
              "dx": {
                "value": -4
              },
              "fill": {
                "value": "#868e96"
              },
              "fontSize": {
                "value": 10
              },
              "text": {
                "signal": "format(datum.value, '.0f')"
              },
              "x": {
                "field": "month",
                "scale": "x"
              },
              "y": {
                "field": "value",
                "scale": "y_local"
              }
            }
          },
          "from": {
            "data": "faceted"
          },
          "transform": [
            {
              "expr": "datum.month === 1",
              "type": "filter"
            }
          ],
          "type": "text"
        },
        {
          "encode": {
            "enter": {
              "align": {
                "value": "left"
              },
              "baseline": {
                "value": "middle"
              },
              "dx": {
                "value": 4
              },
              "fill": {
                "field": "metric",
                "scale": "color"
              },
              "fontSize": {
                "value": 10
              },
              "fontWeight": {
                "value": "bold"
              },
              "text": {
                "signal": "format(datum.value, '.0f')"
              },
              "x": {
                "field": "month",
                "scale": "x"
              },
              "y": {
                "field": "value",
                "scale": "y_local"
              }
            }
          },
          "from": {
            "data": "faceted"
          },
          "transform": [
            {
              "expr": "datum.month === 12",
              "type": "filter"
            }
          ],
          "type": "text"
        }
      ],
      "scales": [
        {
          "domain": {
            "data": "faceted",
            "field": "value"
          },
          "name": "y_local",
          "nice": false,
          "range": [
            {
              "signal": "rowHeight - 28"
            },
            4
          ],
          "type": "linear",
          "zero": false
        }
      ],
      "type": "group"
    },
    {
      "encode": {
        "enter": {
          "align": {
            "value": "right"
          },
          "baseline": {
            "value": "top"
          },
          "fill": {
            "field": "metric",
            "scale": "color"
          },
          "fontSize": {
            "value": 12
          },
          "fontWeight": {
            "value": "600"
          },
          "text": {
            "field": "metric"
          },
          "x": {
            "signal": "labelWidth + 8"
          },
          "y": {
            "field": "metric",
            "offset": 10,
            "scale": "y_facet"
          }
        }
      },
      "from": {
        "data": "metrics"
      },
      "type": "text"
    }
  ],
  "padding": {
    "bottom": 16,
    "left": 24,
    "right": 24,
    "top": 16
  },

  "scales": [
    {
      "domain": [
        "Revenue",
        "Operating Costs",
        "Headcount"
      ],
      "name": "y_facet",
      "range": [
        0,
        120,
        240
      ],
      "type": "ordinal"
    },
    {
      "domain": [
        "Revenue",
        "Operating Costs",
        "Headcount"
      ],
      "name": "color",
      "range": [
        "#1c7ed6",
        "#e8590c",
        "#0ca678"
      ],
      "type": "ordinal"
    },
    {
      "domain": [
        1,
        12
      ],
      "name": "x",
      "range": [
        0,
        360
      ],
      "type": "linear"
    }
  ],

  "signals": [
    {
      "name": "rowHeight",
      "value": 120
    },
    {
      "name": "sparklineWidth",
      "value": 360
    },
    {
      "name": "labelWidth",
      "value": 110
    },
    {
      "name": "hovered",
      "on": [
        {
          "events": "path:pointerover",
          "update": "datum"
        },
        {
          "events": "path:pointerout",
          "update": "null"
        }
      ],
      "value": null
    }
  ],
  "title": {
    "anchor": "start",
    "fontSize": 16,
    "offset": 16,
    "subtitle": "Monthly KPIs Jan–Dec 2024 (indexed to Jan = 100)",
    "subtitleColor": "#868e96",
    "subtitleFontSize": 12,
    "text": "Revenue up 34%, costs and headcount steady through the year"
  },
  "width": 600
}
