{
  "_metadata": {
    "customization": [
      "Replace 'values' array with your data",
      "Change 'metric' field values to your metric names",
      "Update title and subtitle to match your context and units",
      "Adjust 'rowHeight' signal to control vertical spacing",
      "Add or remove metrics — group marks stack automatically"
    ],
    "dataFormat": "Array of objects with 'metric' (nominal), 'month' (ordinal 1-12), and 'value' (quantitative) fields. All metrics share a scale; normalize values to the same unit for meaningful comparison."
  },
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "autosize": {
    "contains": "padding",
    "type": "fit"
  },

  "config": {
    "aria": true,
    "axis": {
      "labelFont": "system-ui, -apple-system, sans-serif",
      "titleFont": "system-ui, -apple-system, sans-serif"
    },
    "title": {
      "font": "system-ui, -apple-system, sans-serif"
    }
  },

  "data": [
    {
