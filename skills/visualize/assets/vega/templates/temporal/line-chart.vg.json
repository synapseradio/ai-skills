{
  "_metadata": {
    "customization": [
      "Replace 'values' array with your time series data",
      "Change field names in scales, axes, and marks to match your data",
      "Update axis titles and format strings to include your units",
      "Modify title and description for your context",
      "Adjust interpolate in the line and area marks ('monotone', 'linear', 'step')",
      "Set 'defined' condition on the line mark to handle nulls differently"
    ],
    "dataFormat": "Array of objects with 'date' (ISO 8601 date string) and 'value' (quantitative) fields. Null values in 'value' create visible gaps in the line.",
    "notes": "Includes a null value in June to demonstrate gap handling. The line mark uses a 'defined' test to break the path at null values. Point marks are filtered to non-null rows."
  },
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "autosize": {
    "contains": "padding",
    "type": "fit"
  },

  "axes": [
    {
      "domainColor": "#dee2e6",
      "format": "%b",
      "grid": true,
      "gridColor": "#f1f3f5",
      "gridDash": [
        2,
        2
      ],
      "labelColor": "#868e96",
      "labelFontSize": 12,
      "orient": "bottom",
      "scale": "x",
      "tickColor": "#dee2e6",
      "tickCount": "month",
      "title": "Month (2024)",
      "titleColor": "#495057",
      "titleFontSize": 13
    },
    {
      "domainColor": "#dee2e6",
      "format": "$,.0f",
      "grid": true,
      "gridColor": "#f1f3f5",
      "gridDash": [
        2,
        2
      ],
      "labelColor": "#868e96",
      "labelFontSize": 12,
      "orient": "left",
      "scale": "y",
      "tickColor": "#dee2e6",
      "title": "Revenue ($)",
      "titleColor": "#495057",
      "titleFontSize": 13
    }
  ],

  "config": {
    "aria": true,
    "axis": {
      "labelFont": "system-ui, -apple-system, sans-serif",
      "titleFont": "system-ui, -apple-system, sans-serif"
    },
    "title": {
      "font": "system-ui, -apple-system, sans-serif"
    }
  },

  "data": [
    {
      "name": "source",
      "transform": [
        {
          "as": "dateVal",
          "expr": "toDate(datum.date)",
          "type": "formula"
        }
      ],
      "values": [
        {
          "date": "2024-01-01",
          "value": 45000
        },
        {
          "date": "2024-02-01",
          "value": 52000
        },
        {
          "date": "2024-03-01",
          "value": 48000
        },
        {
          "date": "2024-04-01",
          "value": 61000
        },
        {
          "date": "2024-05-01",
          "value": 58000
        },
        {
          "date": "2024-06-01",
          "value": null
        },
        {
          "date": "2024-07-01",
          "value": 71000
        },
        {
          "date": "2024-08-01",
          "value": 68000
        },
        {
          "date": "2024-09-01",
          "value": 79000
        },
        {
          "date": "2024-10-01",
          "value": 82000
        },
        {
          "date": "2024-11-01",
          "value": 85000
        },
        {
          "date": "2024-12-01",
          "value": 89000
        }
      ]
    },
    {
      "name": "nonNull",
      "source": "source",
      "transform": [
        {
          "expr": "datum.value !== null",
          "type": "filter"
        }
      ]
    }
  ],
  "description": "Line chart showing monthly revenue over 12 months. Revenue nearly doubled from $45,000 in January to $89,000 in December, with a data gap in June. Growth accelerated in the second half of the year.",
  "height": 400,

  "marks": [
    {
      "encode": {
        "enter": {
          "defined": {
            "signal": "datum.value !== null"
          },
          "interpolate": {
            "value": "monotone"
          },
          "stroke": {
            "value": "#1c7ed6"
          },
          "strokeWidth": {
            "value": 2
          },
          "x": {
            "field": "dateVal",
            "scale": "x"
          },
          "y": {
            "field": "value",
            "scale": "y"
          }
        }
      },
      "from": {
        "data": "source"
      },
      "type": "line"
    },
    {
      "encode": {
        "enter": {
          "shape": {
            "value": "circle"
          },
          "size": {
            "value": 48
          },
          "tooltip": {
            "signal": "{'Month': timeFormat(datum.dateVal, '%B %Y'), 'Revenue ($)': '$' + format(datum.value, ',.0f')}"
          },
          "x": {
            "field": "dateVal",
            "scale": "x"
          },
          "y": {
            "field": "value",
            "scale": "y"
          }
        },
        "update": {
          "fill": {
            "value": "#1c7ed6"
          },
          "opacity": [
            {
              "test": "hovered === null || hovered.date === datum.date",
              "value": 1
            },
            {
              "value": 0.3
            }
          ],
          "stroke": {
            "value": "#ffffff"
          },
          "strokeWidth": {
            "value": 1.5
          }
        }
      },
      "from": {
        "data": "nonNull"
      },
      "type": "symbol"
    }
  ],
  "padding": {
    "bottom": 16,
    "left": 24,
    "right": 24,
    "top": 16
  },

  "scales": [
    {
      "domain": {
        "data": "source",
        "field": "dateVal"
      },
      "name": "x",
      "range": "width",
      "type": "time"
    },
    {
      "domain": {
        "data": "nonNull",
        "field": "value"
      },
      "name": "y",
      "nice": true,
      "range": "height",
      "type": "linear",
      "zero": false
    }
  ],

  "signals": [
    {
      "name": "hovered",
      "on": [
        {
          "events": "symbol:pointerover",
          "update": "datum"
        },
        {
          "events": "symbol:pointerout",
          "update": "null"
        }
      ],
      "value": null
    }
  ],
  "title": {
    "anchor": "start",
    "fontSize": 16,
    "offset": 16,
    "subtitle": "Monthly revenue, 2024 ($)",
    "subtitleColor": "#868e96",
    "subtitleFontSize": 12,
    "text": "Revenue nearly doubled — $45K in January to $89K by December"
  },
  "width": 600
}
