{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "_metadata": {
    "dataFormat": "Array of objects with 'date' (temporal ISO 8601 string), 'open' (quantitative), 'high' (quantitative), 'low' (quantitative), and 'close' (quantitative) fields. One object per trading period.",
    "customization": [
      "Replace 'values' array with your OHLC data",
      "Change field names in the transform, layer encodings, and tooltip definitions",
      "Adjust the bullish/bearish colors in layer[0] and layer[1] color conditions (default: green #26a269 / red #e01b24)",
      "Change layer[1].mark.width to adjust candle body thickness",
      "Adjust axis formats in layer[0].encoding for your price units",
      "Modify title and description for your context"
    ],
    "notes": "Uses a layered spec: layer[0] draws high-low wicks (rule marks), layer[1] draws open-close bodies (bar marks). A calculated 'bullish' field drives conditional coloring."
  },
  "title": "ACME Corp Stock Price (10-Day)",
  "description": "Candlestick chart showing daily OHLC price movements. Green candles indicate bullish days (close above open), red candles indicate bearish days (close below open).",
  "width": "container",
  "height": 400,
  "data": {
    "values": [
      {
        "date": "2024-11-01",
        "open": 142.5,
        "high": 145.2,
        "low": 141.3,
        "close": 144.8
      },
      {
        "date": "2024-11-04",
        "open": 144.9,
        "high": 146.5,
        "low": 143.8,
        "close": 145.2
      },
      {
        "date": "2024-11-05",
        "open": 145.0,
        "high": 147.8,
        "low": 144.5,
        "close": 147.3
      },
      {
        "date": "2024-11-06",
        "open": 147.5,
        "high": 149.2,
        "low": 146.8,
        "close": 148.9
      },
      {
        "date": "2024-11-07",
        "open": 149.0,
        "high": 150.5,
        "low": 147.2,
        "close": 147.8
      },
      {
        "date": "2024-11-08",
        "open": 147.6,
        "high": 148.9,
        "low": 145.3,
        "close": 146.2
      },
      {
        "date": "2024-11-11",
        "open": 146.0,
        "high": 147.5,
        "low": 144.8,
        "close": 145.6
      },
      {
        "date": "2024-11-12",
        "open": 145.8,
        "high": 148.2,
        "low": 145.2,
        "close": 147.9
      },
      {
        "date": "2024-11-13",
        "open": 148.0,
        "high": 151.3,
        "low": 147.5,
        "close": 150.8
      },
      {
        "date": "2024-11-14",
        "open": 151.0,
        "high": 153.2,
        "low": 150.2,
        "close": 152.5
      }
    ]
  },
  "transform": [
    {
      "calculate": "datum.open <= datum.close",
      "as": "bullish"
    }
  ],
  "layer": [
    {
      "description": "High-low range (wicks/shadows)",
      "mark": {
        "type": "rule",
        "tooltip": true
      },
      "encoding": {
        "x": {
          "field": "date",
          "type": "temporal",
          "title": "Date",
          "axis": {
            "format": "%b %d",
            "labelAngle": -45,
            "grid": true,
            "gridDash": [
              2,
              2
            ],
            "gridColor": "#e5e7eb"
          }
        },
        "y": {
          "field": "low",
          "type": "quantitative",
          "title": "Price (USD)",
          "scale": {
            "zero": false
          },
          "axis": {
            "format": "$,.2f",
            "grid": true,
            "gridDash": [
              2,
              2
            ],
            "gridColor": "#e5e7eb"
          }
        },
        "y2": {
          "field": "high"
        },
        "color": {
          "condition": {
            "test": "datum.bullish",
            "value": "#26a269"
          },
          "value": "#e01b24"
        },
        "tooltip": [
          {
            "field": "date",
            "type": "temporal",
            "title": "Date",
            "format": "%B %d, %Y"
          },
          {
            "field": "open",
            "type": "quantitative",
            "title": "Open",
            "format": "$,.2f"
          },
          {
            "field": "high",
            "type": "quantitative",
            "title": "High",
            "format": "$,.2f"
          },
          {
            "field": "low",
            "type": "quantitative",
            "title": "Low",
            "format": "$,.2f"
          },
          {
            "field": "close",
            "type": "quantitative",
            "title": "Close",
            "format": "$,.2f"
          }
        ]
      }
    },
    {
      "description": "Open-close range (candle body)",
      "mark": {
        "type": "bar",
        "tooltip": true,
        "width": 12
      },
      "encoding": {
        "x": {
          "field": "date",
          "type": "temporal"
        },
        "y": {
          "field": "open",
          "type": "quantitative"
        },
        "y2": {
          "field": "close"
        },
        "color": {
          "condition": {
            "test": "datum.bullish",
            "value": "#26a269"
          },
          "value": "#e01b24"
        },
        "tooltip": [
          {
            "field": "date",
            "type": "temporal",
            "title": "Date",
            "format": "%B %d, %Y"
          },
          {
            "field": "open",
            "type": "quantitative",
            "title": "Open",
            "format": "$,.2f"
          },
          {
            "field": "high",
            "type": "quantitative",
            "title": "High",
            "format": "$,.2f"
          },
          {
            "field": "low",
            "type": "quantitative",
            "title": "Low",
            "format": "$,.2f"
          },
          {
            "field": "close",
            "type": "quantitative",
            "title": "Close",
            "format": "$,.2f"
          }
        ]
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelColor": "#6b7280",
      "titleColor": "#374151",
      "tickColor": "#d1d5db",
      "domainColor": "#d1d5db"
    }
  }
}
