{
  "_metadata": {
    "customization": [
      "Replace 'values' array with your time series data",
      "Change field names in scales, axes, and marks to match your data",
      "Update axis titles and format strings to include your units",
      "Modify title and description for your context",
      "To render as overlapping (non-stacked) areas, remove the stack transform and set y0 to the scale zero baseline",
      "Adjust interpolate value ('monotone', 'linear', 'step') for different curve styles"
    ],
    "dataFormat": "Array of objects with 'date' (ISO 8601 date string), 'series' (nominal category), and 'value' (quantitative) fields. One entry per date per series for stacked areas."
  },
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "autosize": {
    "contains": "padding",
    "type": "fit"
  },

  "axes": [
    {
      "domainColor": "#dee2e6",
      "format": "%b",
      "grid": true,
      "gridColor": "#f1f3f5",
      "gridDash": [
        2,
        2
      ],
      "labelColor": "#868e96",
      "labelFontSize": 12,
      "orient": "bottom",
      "scale": "x",
      "tickColor": "#dee2e6",
      "tickCount": "month",
      "title": "Month (2024)",
      "titleColor": "#495057",
      "titleFontSize": 13
    },
    {
      "domainColor": "#dee2e6",
      "format": ",.0f",
      "grid": true,
      "gridColor": "#f1f3f5",
      "gridDash": [
        2,
        2
      ],
      "labelColor": "#868e96",
      "labelFontSize": 12,
      "orient": "left",
      "scale": "y",
      "tickColor": "#dee2e6",
      "title": "Consumption (gallons / kWh)",
      "titleColor": "#495057",
      "titleFontSize": 13
    }
  ],

  "config": {
    "aria": true,
    "axis": {
      "labelFont": "system-ui, -apple-system, sans-serif",
      "titleFont": "system-ui, -apple-system, sans-serif"
    },
    "title": {
      "font": "system-ui, -apple-system, sans-serif"
    }
  },

  "data": [
    {
      "name": "source",
      "transform": [
        {
          "as": "dateVal",
          "expr": "toDate(datum.date)",
          "type": "formula"
        },
        {
          "as": [
            "y0",
            "y1"
          ],
          "field": "value",
          "groupby": [
            "date"
          ],
          "sort": {
            "field": "series",
            "order": "ascending"
          },
          "type": "stack"
        }
      ],
      "values": [
        {
          "date": "2024-01-01",
          "series": "Water",
          "value": 12500
        },
        {
          "date": "2024-02-01",
          "series": "Water",
          "value": 11800
        },
        {
          "date": "2024-03-01",
          "series": "Water",
          "value": 13200
        },
        {
          "date": "2024-04-01",
          "series": "Water",
          "value": 15600
        },
        {
          "date": "2024-05-01",
          "series": "Water",
          "value": 18900
        },
        {
          "date": "2024-06-01",
          "series": "Water",
          "value": 21500
        },
        {
          "date": "2024-07-01",
          "series": "Water",
          "value": 24100
        },
        {
          "date": "2024-08-01",
          "series": "Water",
          "value": 26500
        },
        {
          "date": "2024-09-01",
          "series": "Water",
          "value": 21300
        },
        {
          "date": "2024-10-01",
          "series": "Water",
          "value": 17200
        },
        {
          "date": "2024-11-01",
          "series": "Water",
          "value": 14100
        },
        {
          "date": "2024-12-01",
          "series": "Water",
          "value": 13400
        },
        {
          "date": "2024-01-01",
          "series": "Electricity",
          "value": 8200
        },
        {
          "date": "2024-02-01",
          "series": "Electricity",
          "value": 7800
        },
        {
          "date": "2024-03-01",
          "series": "Electricity",
          "value": 7200
        },
        {
          "date": "2024-04-01",
          "series": "Electricity",
          "value": 6800
        },
        {
          "date": "2024-05-01",
          "series": "Electricity",
          "value": 7500
        },
        {
          "date": "2024-06-01",
          "series": "Electricity",
          "value": 9200
        },
        {
          "date": "2024-07-01",
          "series": "Electricity",
          "value": 10800
        },
        {
          "date": "2024-08-01",
          "series": "Electricity",
          "value": 11500
        },
        {
          "date": "2024-09-01",
          "series": "Electricity",
          "value": 9800
        },
        {
          "date": "2024-10-01",
          "series": "Electricity",
          "value": 8100
        },
        {
          "date": "2024-11-01",
          "series": "Electricity",
          "value": 7900
        },
        {
          "date": "2024-12-01",
          "series": "Electricity",
