      ]
    }
  ],
  "description": "Stacked area chart showing monthly water and electricity consumption across 12 months. Water peaks in August at 26,500 gallons and dominates the summer mix, while electricity peaks at 11,500 kWh. Both decline into autumn.",
  "height": 400,

  "legends": [
    {
      "fill": "color",
      "labelColor": "#868e96",
      "labelFontSize": 12,
      "orient": "top",
      "title": "Resource",
      "titleColor": "#495057",
      "titleFontSize": 12
    }
  ],

  "marks": [
    {
      "from": {
        "facet": {
          "data": "source",
          "groupby": "series",
          "name": "seriesData"
        }
      },
      "marks": [
        {
          "encode": {
            "enter": {
              "interpolate": {
                "value": "monotone"
              },
              "tooltip": {
                "signal": "{'Month': timeFormat(datum.dateVal, '%B %Y'), 'Resource': datum.series, 'Consumption': format(datum.value, ',.0f') + (datum.series === 'Water' ? ' gal' : ' kWh')}"
              },
              "x": {
                "field": "dateVal",
                "scale": "x"
              },
              "y": {
                "field": "y0",
                "scale": "y"
              },
              "y2": {
                "field": "y1",
                "scale": "y"
              }
            },
            "update": {
              "fill": {
                "field": "series",
                "scale": "color"
              },
              "fillOpacity": [
                {
                  "test": "hovered === null || hovered.series === datum.series",
                  "value": 0.7
                },
                {
                  "value": 0.2
                }
              ],
              "stroke": {
                "field": "series",
                "scale": "color"
              },
              "strokeOpacity": [
                {
                  "test": "hovered === null || hovered.series === datum.series",
                  "value": 1
                },
                {
                  "value": 0.3
                }
              ],
              "strokeWidth": {
                "value": 1.5
              }
            }
          },
          "from": {
            "data": "seriesData"
          },
          "type": "area"
        }
      ],
      "type": "group"
    }
  ],
  "padding": {
    "bottom": 16,
    "left": 24,
    "right": 24,
    "top": 16
  },

  "scales": [
    {
      "domain": {
        "data": "source",
        "field": "dateVal"
      },
      "name": "x",
      "range": "width",
      "type": "time"
    },
    {
      "domain": {
        "data": "source",
        "field": "y1"
      },
      "name": "y",
      "nice": true,
      "range": "height",
      "type": "linear",
      "zero": true
    },
    {
      "domain": [
        "Water",
        "Electricity"
      ],
      "name": "color",
      "range": [
        "#1c7ed6",
        "#e8590c"
      ],
      "type": "ordinal"
    }
  ],

  "signals": [
    {
      "name": "hovered",
      "on": [
        {
          "events": "path:pointerover",
          "update": "datum"
        },
        {
          "events": "path:pointerout",
          "update": "null"
        }
      ],
      "value": null
    }
  ],
  "title": {
    "anchor": "start",
    "fontSize": 16,
    "offset": 16,
    "subtitle": "Monthly resource consumption by category, 2024 (gallons / kWh)",
    "subtitleColor": "#868e96",
    "subtitleFontSize": 12,
    "text": "Water drives peak summer consumption — 70% of July total"
  },
  "width": 600
}
