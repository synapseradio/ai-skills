{
  "_metadata": {
    "customization": [
      "Replace 'values' array with your data",
      "Change field names in scales, axes, and marks to match your data",
      "Update left/right axis titles to reflect your time points",
      "Modify title and description for your context",
      "Increase/decrease strokeWidth on line marks to adjust line weight"
    ],
    "dataFormat": "Array of objects with 'department' (nominal), 'before' (quantitative), and 'after' (quantitative) fields"
  },
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "autosize": {
    "contains": "padding",
    "type": "fit"
  },

  "axes": [
    {
      "domainColor": "#dee2e6",
      "labelColor": "#868e96",
      "labelFontSize": 12,
      "offset": {
        "signal": "-(leftX - 24)"
      },
      "orient": "left",
      "scale": "yBefore",
      "tickColor": "#dee2e6",
      "title": "Score: Before",
      "titleColor": "#495057",
      "titleFontSize": 13
    },
    {
      "domainColor": "#dee2e6",
      "labelColor": "#868e96",
      "labelFontSize": 12,
      "offset": {
        "signal": "width - rightX - 24"
      },
      "orient": "right",
      "scale": "yAfter",
      "tickColor": "#dee2e6",
      "title": "Score: After",
      "titleColor": "#495057",
      "titleFontSize": 13
    }
  ],

  "config": {
    "aria": true,
    "axis": {
      "labelFont": "system-ui, -apple-system, sans-serif",
      "titleFont": "system-ui, -apple-system, sans-serif"
    },
    "title": {
      "font": "system-ui, -apple-system, sans-serif"
    }
  },

  "data": [
    {
      "name": "source",
      "transform": [
        {
          "as": "direction",
          "expr": "datum.after >= datum.before ? 'increase' : 'decrease'",
          "type": "formula"
        }
      ],
      "values": [
        {
          "after": 80,
          "before": 62,
          "department": "Engineering"
        },
        {
          "after": 71,
          "before": 55,
          "department": "Sales"
        },
        {
          "after": 78,
          "before": 70,
          "department": "Marketing"
        },
        {
          "after": 76,
          "before": 74,
          "department": "Operations"
        },
        {
          "after": 65,
          "before": 68,
          "department": "HR"
        },
        {
          "after": 76,
          "before": 80,
          "department": "Customer Support"
        }
      ]
    }
  ],
  "description": "Slope chart showing before/after training scores for 6 departments. Engineering gained 18 points; Customer Support declined 4 points.",
  "height": 420,

  "legends": [
    {
      "fill": "color",
      "labelColor": "#495057",
      "labelFontSize": 11,
      "orient": "top-right",
      "symbolSize": 60,
      "title": "Direction",
      "titleColor": "#495057",
      "titleFontSize": 12
    }
  ],

  "marks": [
    {
      "encode": {
        "enter": {
          "align": {
            "value": "center"
          },
          "fill": {
            "value": "#495057"
          },
          "fontSize": {
            "value": 12
          },
          "fontWeight": {
            "value": "bold"
          },
          "text": {
            "value": "Before"
          },
          "x": {
            "signal": "leftX"
          },
          "y": {
            "value": -8
          }
        }
      },
      "type": "text"
    },
    {
      "encode": {
        "enter": {
          "align": {
            "value": "center"
          },
          "fill": {
            "value": "#495057"
          },
          "fontSize": {
            "value": 12
          },
          "fontWeight": {
            "value": "bold"
          },
          "text": {
            "value": "After"
          },
          "x": {
            "signal": "rightX"
          },
          "y": {
            "value": -8
          }
        }
      },
      "type": "text"
    },
    {
      "encode": {
        "enter": {
          "stroke": {
            "value": "#dee2e6"
          },
          "strokeWidth": {
            "value": 1
          },
          "x": {
            "signal": "leftX"
          },
          "x2": {
            "signal": "leftX"
          },
          "y": {
            "value": 0
          },
          "y2": {
            "signal": "height"
          }
        }
      },
      "type": "rule"
    },
    {
      "encode": {
        "enter": {
          "stroke": {
            "value": "#dee2e6"
          },
          "strokeWidth": {
            "value": 1
          },
          "x": {
            "signal": "rightX"
          },
          "x2": {
            "signal": "rightX"
          },
          "y": {
            "value": 0
          },
          "y2": {
            "signal": "height"
          }
        }
      },
      "type": "rule"
    },
    {
      "encode": {
        "enter": {
          "tooltip": {
            "signal": "{'Department': datum.department, 'Before': datum.before + ' pts', 'After': datum.after + ' pts', 'Change': (datum.after - datum.before > 0 ? '+' : '') + (datum.after - datum.before) + ' pts'}"
          },
          "x": {
            "signal": "leftX"
          },
          "x2": {
            "signal": "rightX"
          },
          "y": {
            "field": "before",
            "scale": "yBefore"
          },
          "y2": {
            "field": "after",
            "scale": "yAfter"
          }
        },
        "update": {
          "opacity": [
            {
              "test": "hovered === null || hovered.department === datum.department",
              "value": 0.85
            },
            {
              "value": 0.1
            }
          ],
          "stroke": {
            "field": "direction",
            "scale": "color"
          },
          "strokeWidth": {
            "value": 2
          }
        }
      },
      "from": {
        "data": "source"
      },
      "type": "rule"
    },
    {
      "encode": {
        "enter": {
          "shape": {
            "value": "circle"
          },
          "size": {
            "value": 80
          },
          "tooltip": {
            "signal": "{'Department': datum.department, 'Before': datum.before + ' pts'}"
          },
          "x": {
            "signal": "leftX"
          },
          "y": {
            "field": "before",
            "scale": "yBefore"
          }
        },
        "update": {
          "fill": {
            "field": "direction",
            "scale": "color"
          },
          "opacity": [
            {
              "test": "hovered === null || hovered.department === datum.department",
              "value": 1
            },
            {
              "value": 0.1
            }
          ]
        }
      },
      "from": {
        "data": "source"
      },
      "type": "symbol"
    },
    {
      "encode": {
        "enter": {
          "shape": {
            "value": "circle"
          },
          "size": {
            "value": 80
          },
          "tooltip": {
            "signal": "{'Department': datum.department, 'After': datum.after + ' pts'}"
          },
          "x": {
            "signal": "rightX"
          },
          "y": {
            "field": "after",
            "scale": "yAfter"
          }
        },
        "update": {
          "fill": {
            "field": "direction",
            "scale": "color"
          },
          "opacity": [
            {
              "test": "hovered === null || hovered.department === datum.department",
              "value": 1
            },
            {
              "value": 0.1
            }
          ]
        }
      },
      "from": {
        "data": "source"
      },
      "type": "symbol"
    },
    {
      "encode": {
        "enter": {
          "align": {
            "value": "right"
          },
          "baseline": {
            "value": "middle"
          },
          "fontSize": {
            "value": 11
          },
          "text": {
            "field": "department"
          },
          "x": {
            "signal": "leftX - 8"
          },
          "y": {
            "field": "before",
            "scale": "yBefore"
          }
        },
        "update": {
          "fill": {
            "value": "#868e96"
          },
          "opacity": [
            {
              "test": "hovered === null || hovered.department === datum.department",
              "value": 1
            },
            {
              "value": 0.2
            }
          ]
        }
      },
      "from": {
        "data": "source"
      },
      "type": "text"
    }
  ],
  "padding": {
    "bottom": 16,
    "left": 24,
    "right": 24,
    "top": 16
  },

  "scales": [
    {
      "domain": [
        0,
        100
      ],
      "name": "yBefore",
      "nice": true,
      "range": "height",
      "type": "linear",
      "zero": true
    },
    {
      "domain": [
        0,
        100
      ],
      "name": "yAfter",
      "nice": true,
      "range": "height",
      "type": "linear",
      "zero": true
    },
    {
      "domain": [
        "increase",
        "decrease"
      ],
      "name": "color",
      "range": [
        "#0ca678",
        "#f03e3e"
      ],
      "type": "ordinal"
    }
  ],

  "signals": [
    {
      "name": "hovered",
      "on": [
        {
          "events": "line:pointerover",
          "update": "datum"
        },
        {
          "events": "symbol:pointerover",
          "update": "datum"
        },
        {
          "events": "line:pointerout",
          "update": "null"
        },
        {
          "events": "symbol:pointerout",
          "update": "null"
        }
      ],
      "value": null
    },
    {
      "name": "leftX",
      "value": 80
    },
    {
      "name": "rightX",
      "value": 420
    }
  ],
  "title": {
    "anchor": "start",
    "fontSize": 16,
    "offset": 16,
    "subtitle": "Department performance scores: Before vs After training (0–100 scale)",
    "subtitleColor": "#868e96",
    "subtitleFontSize": 12,
    "text": "Engineering and Sales show the largest score gains"
  },
  "width": 500
}
