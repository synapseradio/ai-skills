{
  "_metadata": {
    "customization": [
      "Replace 'values' in data[0] (node-data) with your nodes",
      "Replace 'values' in data[1] (link-data) with your edges using 0-based node indices",
      "Add a 'value' or 'weight' field to link-data for weighted edges",
      "Adjust signal defaults: 'nodeRadius', 'nbodyStrength', 'linkDistance' to tune layout",
      "Update scales[0].domain or color scheme for your group categories",
      "Modify title.text and description for your context"
    ],
    "dataFormat": "Two arrays: 'node-data' with objects containing 'name' (string label) and 'group' (nominal category); 'link-data' with objects containing 'source' (integer index into node-data) and 'target' (integer index into node-data).",
    "notes": "Nodes are draggable. Hover highlights connected edges. Link source/target values are 0-based indices into the node-data array, not id strings."
  },
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "autosize": "none",
  "config": {
    "aria": true,
    "axis": {
      "labelFont": "system-ui, -apple-system, sans-serif",
      "titleFont": "system-ui, -apple-system, sans-serif"
    },
    "title": {
      "font": "system-ui, -apple-system, sans-serif"
    },
    "view": {
      "stroke": null
    }
  },
  "data": [
    {
      "name": "node-data",
      "values": [
        {
          "group": "Engineering",
          "name": "Alice"
        },
        {
          "group": "Engineering",
          "name": "Bob"
        },
        {
          "group": "Design",
          "name": "Carol"
        },
        {
          "group": "Engineering",
          "name": "Dave"
        },
        {
          "group": "Product",
          "name": "Eve"
        },
        {
          "group": "Design",
          "name": "Frank"
        },
        {
          "group": "Product",
          "name": "Grace"
        },
        {
          "group": "Engineering",
          "name": "Henry"
        }
      ]
    },
    {
      "name": "link-data",
      "values": [
        {
          "source": 0,
          "target": 1
        },
        {
          "source": 0,
          "target": 2
        },
        {
          "source": 0,
          "target": 4
        },
        {
          "source": 1,
          "target": 3
        },
        {
          "source": 1,
          "target": 7
        },
        {
          "source": 2,
          "target": 5
        },
        {
          "source": 3,
          "target": 7
        },
        {
          "source": 4,
          "target": 6
        },
        {
          "source": 5,
          "target": 2
        },
        {
          "source": 6,
          "target": 4
        }
      ]
    }
  ],
  "description": "Force-directed network graph showing social connections between people across departments. Nodes are colored by group and sized by connection count.",
  "height": 500,
  "legends": [
    {
      "encode": {
        "labels": {
          "update": {
            "fill": {
              "value": "#666"
            },
            "fontSize": {
              "value": 11
            }
          }
        },
        "symbols": {
          "update": {
            "size": {
              "value": 100
            },
            "strokeWidth": {
              "value": 0
            }
          }
        },
        "title": {
          "update": {
            "fill": {
              "value": "#333"
            },
            "fontSize": {
              "value": 12
            }
          }
        }
      },
      "fill": "color",
      "orient": "top-left",
      "title": "Department"
    }
  ],
  "marks": [
    {
      "encode": {
        "update": {
          "stroke": {
            "value": "#ccc"
          },
          "strokeOpacity": {
            "signal": "hovered == null ? 0.6 : (hovered === datum.source || hovered === datum.target ? 1 : 0.1)"
          },
          "strokeWidth": {
            "value": 1.5
          }
        }
      },
      "from": {
        "data": "link-data"
      },
      "interactive": false,
      "name": "edges",
      "transform": [
        {
          "require": {
            "signal": "force"
          },
          "shape": "line",
          "sourceX": "datum.source.x",
          "sourceY": "datum.source.y",
          "targetX": "datum.target.x",
          "targetY": "datum.target.y",
          "type": "linkpath"
        }
      ],
      "type": "path"
    },
    {
      "encode": {
        "enter": {
          "fill": {
            "field": "group",
            "scale": "color"
          },
          "stroke": {
            "value": "#fff"
          },
          "strokeWidth": {
            "value": 2
          },
          "tooltip": {
            "signal": "{ 'Name': datum.name, 'Group': datum.group }"
          }
        },
        "update": {
          "cursor": {
            "value": "pointer"
          },
          "fx": {
            "signal": "dragged === datum ? fx : null"
          },
          "fy": {
            "signal": "dragged === datum ? fy : null"
          },
          "opacity": {
            "signal": "hovered == null ? 1 : (hovered === datum || indata('link-data', 'source', hovered.index) && datum.index === data('link-data')[indexof(pluck(data('link-data'), 'source'), hovered.index)].target ? 1 : 0.3)"
          },
          "size": {
            "signal": "pow(2 * nodeRadius, 2)"
          }
        }
      },
      "from": {
        "data": "node-data"
      },
      "name": "nodes",
      "transform": [
        {
          "forces": [
            {
              "force": "center",
              "x": {
                "signal": "cx"
              },
              "y": {
                "signal": "cy"
              }
            },
            {
              "force": "collide",
              "radius": {
                "signal": "nodeRadius + 2"
              }
            },
            {
              "force": "nbody",
              "strength": {
                "signal": "nbodyStrength"
              }
            },
            {
              "distance": {
                "signal": "linkDistance"
              },
              "force": "link",
              "links": "link-data"
            }
          ],
          "iterations": 300,
          "restart": {
            "signal": "dragged"
          },
          "signal": "force",
          "type": "force"
        }
      ],
      "type": "symbol",
      "zindex": 1
    },
    {
      "encode": {
        "enter": {
          "align": {
            "value": "center"
          },
          "baseline": {
            "value": "top"
          },
          "fill": {
            "value": "#333"
          },
          "fontSize": {
            "value": 10
          },
          "text": {
            "field": "datum.name"
          }
        },
        "update": {
          "x": {
            "field": "x"
          },
          "y": {
            "signal": "datum.y + nodeRadius + 4"
          }
        }
      },
      "from": {
        "data": "nodes"
      },
      "interactive": false,
      "type": "text",
      "zindex": 2
    }
  ],
  "padding": {
    "bottom": 16,
    "left": 24,
    "right": 24,
    "top": 16
  },
  "scales": [
    {
      "domain": {
        "data": "node-data",
        "field": "group"
      },
      "name": "color",
      "range": [
        "#1c7ed6",
        "#e8590c",
        "#0ca678",
        "#f03e3e",
        "#ae3ec9",
        "#1098ad",
        "#74b816",
        "#d6336c"
      ],
      "type": "ordinal"
    }
  ],
  "signals": [
    {
      "name": "cx",
      "update": "width / 2"
    },
    {
      "name": "cy",
      "update": "height / 2"
    },
    {
      "name": "nodeRadius",
      "value": 8
    },
    {
      "name": "nbodyStrength",
      "value": -30
    },
    {
      "name": "linkDistance",
      "value": 40
    },
    {
      "name": "dragged",
      "on": [
        {
          "events": "symbol:pointerdown",
          "update": "datum"
        },
        {
          "events": "window:pointerup",
          "update": "null"
        }
      ],
      "value": null
    },
    {
      "name": "fx",
      "on": [
        {
          "events": "symbol:pointerdown",
          "update": "datum.x"
        },
        {
          "events": "[symbol:pointerdown, window:pointerup] > window:pointermove",
          "update": "dragged ? clamp(x(), 0, width) : fx"
        },
        {
          "events": "window:pointerup",
          "update": "null"
        }
      ],
      "value": null
    },
    {
      "name": "fy",
      "on": [
        {
          "events": "symbol:pointerdown",
          "update": "datum.y"
        },
        {
          "events": "[symbol:pointerdown, window:pointerup] > window:pointermove",
          "update": "dragged ? clamp(y(), 0, height) : fy"
        },
        {
          "events": "window:pointerup",
          "update": "null"
        }
      ],
      "value": null
    },
    {
      "name": "hovered",
      "on": [
        {
          "events": "symbol:pointerover",
          "update": "datum"
        },
        {
          "events": "symbol:pointerout",
          "update": "null"
        }
      ],
      "value": null
    }
  ],
  "title": {
    "anchor": "start",
    "fontSize": 16,
    "offset": 16,
    "subtitle": "Team connection network — drag nodes to rearrange, hover to highlight edges",
    "subtitleColor": "#868e96",
    "subtitleFontSize": 12,
    "text": "Engineering and Product are the densest cross-team connectors"
  },
  "width": 700
}
