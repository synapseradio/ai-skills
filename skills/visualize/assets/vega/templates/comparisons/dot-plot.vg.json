{
  "_metadata": {
    "customization": [
      "Replace 'values' array with your data",
      "Change field names in scales and marks to match your data",
      "Update axis title and tooltip to reflect your units",
      "Modify title and description for your context",
      "Adjust symbol size via the 'size' encode property on the symbol mark"
    ],
    "dataFormat": "Array of objects with 'country' (nominal) and 'gdp' (quantitative, USD) fields"
  },
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "autosize": {
    "contains": "padding",
    "type": "fit"
  },

  "axes": [
    {
      "domainColor": "#dee2e6",
      "format": "$,.0f",
      "grid": true,
      "gridColor": "#f1f3f5",
      "gridDash": [
        2,
        2
      ],
      "labelColor": "#868e96",
      "labelFontSize": 12,
      "orient": "bottom",
      "scale": "x",
      "tickColor": "#dee2e6",
      "title": "GDP per capita (USD)",
      "titleColor": "#495057",
      "titleFontSize": 13
    },
    {
      "domainColor": "#dee2e6",
      "labelColor": "#868e96",
      "labelFontSize": 12,
      "orient": "left",
      "scale": "y",
      "tickColor": "#dee2e6"
    }
  ],

  "config": {
    "aria": true,
    "axis": {
      "labelFont": "system-ui, -apple-system, sans-serif",
      "titleFont": "system-ui, -apple-system, sans-serif"
    },
    "title": {
      "font": "system-ui, -apple-system, sans-serif"
    }
  },

  "data": [
    {
      "name": "source",
      "transform": [
        {
          "sort": {
            "field": "gdp",
            "order": "descending"
          },
          "type": "collect"
        }
      ],
      "values": [
        {
          "country": "Luxembourg",
          "gdp": 128400
        },
        {
          "country": "Switzerland",
          "gdp": 98600
        },
        {
          "country": "Norway",
          "gdp": 89700
        },
        {
          "country": "United States",
          "gdp": 76300
        },
        {
          "country": "Denmark",
          "gdp": 68200
        },
        {
          "country": "Australia",
          "gdp": 64100
        },
        {
          "country": "Germany",
          "gdp": 54300
        },
        {
          "country": "Japan",
          "gdp": 42200
        }
      ]
    }
  ],
  "description": "Dot (lollipop) plot comparing GDP per capita across 8 countries. Luxembourg leads at $128K, followed by Switzerland at $98K.",
  "height": 400,

  "marks": [
    {
      "encode": {
        "enter": {
          "x": {
            "scale": "x",
            "value": 0
          },
          "x2": {
            "field": "gdp",
            "scale": "x"
          },
          "y": {
            "band": 0.5,
            "field": "country",
            "scale": "y"
          }
        },
        "update": {
          "opacity": [
            {
              "test": "hovered === null || hovered.country === datum.country",
              "value": 1
            },
            {
              "value": 0.2
            }
          ],
          "stroke": {
            "field": "country",
            "scale": "color"
          },
          "strokeWidth": {
            "value": 2
          }
        }
      },
      "from": {
        "data": "source"
      },
      "type": "rule"
    },
    {
      "encode": {
        "enter": {
          "shape": {
            "value": "circle"
          },
          "size": {
            "value": 120
          },
          "tooltip": {
            "signal": "{'Country': datum.country, 'GDP per capita': '$' + format(datum.gdp, ',.0f')}"
          },
          "x": {
            "field": "gdp",
            "scale": "x"
          },
          "y": {
            "band": 0.5,
            "field": "country",
            "scale": "y"
          }
        },
        "update": {
          "fill": {
            "field": "country",
            "scale": "color"
          },
          "opacity": [
            {
              "test": "hovered === null || hovered.country === datum.country",
              "value": 1
            },
            {
              "value": 0.2
            }
          ]
        }
      },
      "from": {
        "data": "source"
      },
      "type": "symbol"
    }
  ],
  "padding": {
    "bottom": 16,
    "left": 24,
    "right": 24,
    "top": 16
  },

  "scales": [
    {
      "domain": {
        "data": "source",
        "field": "country"
      },
      "name": "y",
      "padding": 0.4,
      "range": "height",
      "type": "band"
    },
    {
      "domain": {
        "data": "source",
        "field": "gdp"
      },
      "name": "x",
      "nice": true,
      "range": "width",
      "type": "linear",
      "zero": true
    },
    {
      "domain": {
        "data": "source",
        "field": "country"
      },
      "name": "color",
      "range": [
        "#1c7ed6",
        "#e8590c",
        "#0ca678",
        "#f03e3e",
        "#ae3ec9",
        "#1098ad",
        "#74b816",
        "#d6336c"
      ],
      "type": "ordinal"
    }
  ],

  "signals": [
    {
      "name": "hovered",
      "on": [
        {
          "events": "symbol:pointerover",
          "update": "datum"
        },
        {
          "events": "symbol:pointerout",
          "update": "null"
        }
      ],
      "value": null
    }
  ],
  "title": {
    "anchor": "start",
    "fontSize": 16,
    "offset": 16,
    "subtitle": "GDP per capita by country, 2023 (USD, thousands)",
    "subtitleColor": "#868e96",
    "subtitleFontSize": 12,
    "text": "Luxembourg leads GDP per capita among surveyed nations"
  },
  "width": 600
}
