{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "_metadata": {
    "dataFormat": "Array of objects with 'category' (nominal) and 'value' (quantitative) fields. Each object represents one slice.",
    "customization": [
      "Replace 'values' array with your data",
      "Change field names in encoding.theta.field, encoding.color.field, and tooltip fields",
      "Set mark.innerRadius > 0 (e.g., 50) to create a donut chart",
      "Update encoding.color.legend.title for your category label",
      "Modify title and description for your context"
    ]
  },
  "title": "Budget Allocation by Department",
  "description": "Pie chart showing budget allocation across 6 departments: Engineering 35%, Marketing 28%, Sales 22%, Operations 8%, Finance 5%, and Other 2%. Total budget: $1,000,000.",
  "width": 400,
  "height": 400,
  "data": {
    "values": [
      {
        "category": "Engineering",
        "value": 350000
      },
      {
        "category": "Marketing",
        "value": 280000
      },
      {
        "category": "Sales",
        "value": 220000
      },
      {
        "category": "Operations",
        "value": 80000
      },
      {
        "category": "Finance",
        "value": 50000
      },
      {
        "category": "Other",
        "value": 20000
      }
    ]
  },
  "mark": {
    "type": "arc",
    "tooltip": true,
    "innerRadius": 0,
    "stroke": "white",
    "strokeWidth": 2
  },
  "encoding": {
    "theta": {
      "field": "value",
      "type": "quantitative",
      "stack": true
    },
    "color": {
      "field": "category",
      "type": "nominal",
      "scale": {
        "scheme": "tableau10"
      },
      "legend": {
        "title": "Department",
        "orient": "right"
      }
    },
    "tooltip": [
      {
        "field": "category",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "value",
        "type": "quantitative",
        "title": "Budget ($)",
        "format": "$,.0f"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    }
  }
}
