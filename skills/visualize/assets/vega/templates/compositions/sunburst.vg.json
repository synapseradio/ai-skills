{
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "_metadata": {
    "dataFormat": "Array of objects with 'id' (unique string), 'parent' (string referencing another id, or null for root), and 'value' (quantitative, null for branch nodes) fields. Hierarchical parent-child structure with 3+ depth levels.",
    "customization": [
      "Replace 'values' array in data[0] with your hierarchical data",
      "Update scales[0].domain with your top-level category names",
      "Update scales[0].range with colors for each top-level category",
      "Adjust the partition size parameter (data[0].transform[1].size[1]) to control outer radius",
      "Modify title.text and description for your context"
    ],
    "notes": "Leaf nodes must have numeric 'value'; branch nodes should have null 'value'. The stratify transform builds the hierarchy from id/parent fields."
  },
  "description": "Sunburst chart showing disk storage usage across Documents, Media, Applications, and System categories with 3-level hierarchy.",
  "width": 600,
  "height": 600,
  "padding": 5,
  "autosize": "none",
  "title": {
    "text": "Disk Storage Usage by Folder",
    "anchor": "start",
    "fontSize": 16
  },
  "data": [
    {
      "name": "tree",
      "values": [
        {
          "id": "Storage",
          "parent": null,
          "value": null
        },
        {
          "id": "Documents",
          "parent": "Storage",
          "value": null
        },
        {
          "id": "Work",
          "parent": "Documents",
          "value": null
        },
        {
          "id": "Reports",
          "parent": "Work",
          "value": 850
        },
        {
          "id": "Presentations",
          "parent": "Work",
          "value": 620
        },
        {
          "id": "Spreadsheets",
          "parent": "Work",
          "value": 480
        },
        {
          "id": "Personal",
          "parent": "Documents",
          "value": null
        },
        {
          "id": "Taxes",
          "parent": "Personal",
          "value": 320
        },
        {
          "id": "Receipts",
          "parent": "Personal",
          "value": 180
        },
        {
          "id": "Archive",
          "parent": "Documents",
          "value": null
        },
        {
          "id": "2023 Files",
          "parent": "Archive",
          "value": 1200
        },
        {
          "id": "2022 Files",
          "parent": "Archive",
          "value": 980
        },
        {
          "id": "Media",
          "parent": "Storage",
          "value": null
        },
        {
          "id": "Photos",
          "parent": "Media",
          "value": null
        },
        {
          "id": "Vacations",
          "parent": "Photos",
          "value": 4200
        },
        {
          "id": "Family",
          "parent": "Photos",
          "value": 2800
        },
        {
          "id": "Videos",
          "parent": "Media",
          "value": null
        },
        {
          "id": "Projects",
          "parent": "Videos",
          "value": 6500
        },
        {
          "id": "Tutorials",
          "parent": "Videos",
          "value": 1700
        },
        {
          "id": "Music",
          "parent": "Media",
          "value": null
        },
        {
          "id": "Albums",
          "parent": "Music",
          "value": 2400
        },
        {
          "id": "Podcasts",
          "parent": "Music",
          "value": 600
        },
        {
          "id": "Applications",
          "parent": "Storage",
          "value": null
        },
        {
          "id": "Development",
          "parent": "Applications",
          "value": null
        },
        {
          "id": "IDEs",
          "parent": "Development",
          "value": 3200
        },
        {
          "id": "SDKs",
          "parent": "Development",
          "value": 2100
        },
        {
          "id": "Games",
          "parent": "Applications",
          "value": null
        },
        {
          "id": "Strategy",
          "parent": "Games",
          "value": 4500
        },
        {
          "id": "Adventure",
          "parent": "Games",
          "value": 3200
        },
        {
          "id": "System",
          "parent": "Storage",
          "value": null
        },
        {
          "id": "OS Files",
          "parent": "System",
          "value": 5400
        },
        {
          "id": "Cache",
          "parent": "System",
          "value": 2100
        },
        {
          "id": "Logs",
          "parent": "System",
          "value": 800
        }
      ],
      "transform": [
        {
          "type": "stratify",
          "key": "id",
          "parentKey": "parent"
        },
        {
          "type": "partition",
          "field": "value",
          "sort": {
            "field": "value",
            "order": "descending"
          },
          "size": [
            6.283185307179586,
            270
          ],
          "as": [
            "a0",
            "r0",
            "a1",
            "r1",
            "depth",
            "children"
          ]
        }
      ]
    }
  ],
  "scales": [
    {
      "name": "color",
      "type": "ordinal",
      "domain": [
        "Documents",
        "Media",
        "Applications",
        "System"
      ],
      "range": [
        "#4e79a7",
        "#f28e2c",
        "#e15759",
        "#76b7b2"
      ]
    }
  ],
  "marks": [
    {
      "type": "arc",
      "from": {
        "data": "tree"
      },
      "encode": {
        "enter": {
          "x": {
            "signal": "width / 2"
          },
          "y": {
            "signal": "height / 2"
          },
          "tooltip": {
            "signal": "datum.depth > 0 ? { 'Name': datum.id, 'Parent': datum.parent, 'Size (MB)': datum.value || datum.value === 0 ? datum.value : null } : null"
          }
        },
        "update": {
          "startAngle": {
            "field": "a0"
          },
          "endAngle": {
            "field": "a1"
          },
          "innerRadius": {
            "field": "r0"
          },
          "outerRadius": {
            "field": "r1"
          },
          "stroke": {
            "value": "white"
          },
          "strokeWidth": {
            "value": 0.5
          },
          "fill": [
            {
              "test": "datum.depth === 0",
              "value": "transparent"
            },
            {
              "test": "datum.depth === 1",
              "scale": "color",
              "field": "id"
            },
            {
              "test": "datum.depth === 2",
              "signal": "scale('color', datum.parent)"
            },
            {
              "signal": "scale('color', data('tree')[datum.index] ? pluck(data('tree'), 'parent')[pluck(data('tree'), 'id').indexOf(datum.parent)] : datum.parent)"
            }
          ],
          "fillOpacity": [
            {
              "test": "datum.depth === 0",
              "value": 0
            },
            {
              "test": "datum.depth === 1",
              "value": 1
            },
            {
              "test": "datum.depth === 2",
              "value": 0.75
            },
            {
              "value": 0.55
            }
          ]
        },
        "hover": {
          "fillOpacity": [
            {
              "test": "datum.depth === 0",
              "value": 0
            },
            {
              "value": 0.9
            }
          ]
        }
      }
    },
    {
      "type": "text",
      "from": {
        "data": "tree"
      },
      "encode": {
        "enter": {
          "x": {
            "signal": "width / 2"
          },
          "y": {
            "signal": "height / 2"
          },
          "fill": {
            "value": "white"
          },
          "fontSize": {
            "value": 10
          },
          "fontWeight": {
            "value": "bold"
          },
          "baseline": {
            "value": "middle"
          },
          "align": {
            "value": "center"
          }
        },
        "update": {
          "theta": {
            "signal": "(datum.a0 + datum.a1) / 2"
          },
          "radius": {
            "signal": "(datum.r0 + datum.r1) / 2"
          },
          "text": {
            "signal": "(datum.a1 - datum.a0) > 0.2 && datum.depth > 0 ? datum.id : ''"
          },
          "opacity": {
            "signal": "(datum.a1 - datum.a0) > 0.2 && datum.depth > 0 ? 1 : 0"
          }
        }
      }
    }
  ]
}
