{
  "_metadata": {
    "customization": [
      "Replace 'values' array in data[0] with your hierarchical data",
      "Update scales[0].domain with your top-level category names",
      "Update scales[0].range with colors for each top-level category",
      "Adjust treemap transform parameters: 'method', 'paddingInner', 'paddingOuter', 'paddingTop'",
      "Modify title.text and description for your context"
    ],
    "dataFormat": "Array of objects with 'id' (unique string), 'parent' (string referencing another id, or null for root), and 'value' (quantitative, null for branch nodes) fields. Two-level hierarchy: root -> categories -> leaf items.",
    "notes": "Leaf nodes must have numeric 'value'; branch nodes should have null 'value'. The squarify method with golden-ratio produces visually balanced rectangles."
  },
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "autosize": {
    "contains": "padding",
    "type": "fit"
  },

  "config": {
    "aria": true,
    "axis": {
      "labelFont": "system-ui, -apple-system, sans-serif",
      "titleFont": "system-ui, -apple-system, sans-serif"
    },
    "title": {
      "font": "system-ui, -apple-system, sans-serif"
    }
  },
  "data": [
    {
      "name": "tree",
      "transform": [
        {
          "key": "id",
          "parentKey": "parent",
          "type": "stratify"
        },
        {
          "field": "value",
          "method": "squarify",
          "paddingInner": 2,
          "paddingOuter": 4,
          "paddingTop": 20,
          "ratio": 1.6180339887,
          "round": true,
          "size": [
            {
              "signal": "width"
            },
            {
              "signal": "height"
            }
          ],
          "type": "treemap"
        }
      ],
      "values": [
        {
          "id": "Storage",
          "parent": null,
          "value": null
        },
        {
          "id": "Documents",
          "parent": "Storage",
          "value": null
        },
        {
          "id": "Work",
          "parent": "Documents",
          "value": 2400
        },
        {
          "id": "Personal",
          "parent": "Documents",
          "value": 1800
        },
        {
          "id": "Archive",
          "parent": "Documents",
          "value": 3200
        },
        {
          "id": "Media",
          "parent": "Storage",
          "value": null
        },
        {
          "id": "Photos",
          "parent": "Media",
          "value": 8500
        },
        {
          "id": "Videos",
          "parent": "Media",
          "value": 12000
        },
        {
          "id": "Music",
          "parent": "Media",
          "value": 4200
        },
        {
          "id": "Applications",
          "parent": "Storage",
          "value": null
        },
        {
          "id": "Productivity",
          "parent": "Applications",
          "value": 3800
        },
        {
          "id": "Development",
          "parent": "Applications",
          "value": 6500
        },
        {
          "id": "Games",
          "parent": "Applications",
          "value": 9200
        },
        {
          "id": "Utilities",
          "parent": "Applications",
          "value": 1200
        },
        {
          "id": "System",
          "parent": "Storage",
          "value": null
        },
        {
          "id": "OS Files",
          "parent": "System",
          "value": 5400
        },
        {
          "id": "Cache",
          "parent": "System",
          "value": 2100
        },
        {
          "id": "Logs",
          "parent": "System",
          "value": 800
        },
        {
          "id": "Downloads",
          "parent": "Storage",
          "value": null
        },
        {
          "id": "Recent",
          "parent": "Downloads",
          "value": 1500
        },
        {
          "id": "Pending",
          "parent": "Downloads",
          "value": 600
        }
      ]
    },
    {
      "name": "leaves",
      "source": "tree",
      "transform": [
        {
          "expr": "!datum.children",
          "type": "filter"
        }
      ]
    },
    {
      "name": "branches",
      "source": "tree",
      "transform": [
        {
          "expr": "datum.children && datum.depth === 1",
          "type": "filter"
        }
      ]
    }
  ],
  "description": "Treemap showing file system storage usage across Documents, Media, Applications, System, and Downloads categories. Media dominates with Photos and Videos as largest items.",
  "height": 450,
  "marks": [
    {
      "encode": {
        "enter": {
          "tooltip": {
            "signal": "{ 'Category': datum.id, 'Total (MB)': datum.value }"
          }
        },
        "update": {
          "cornerRadius": {
            "value": 3
          },
          "fill": {
            "field": "id",
            "scale": "color"
          },
          "fillOpacity": {
            "value": 0.25
          },
          "stroke": {
            "field": "id",
            "scale": "color"
          },
          "strokeWidth": {
            "value": 1.5
          },
          "x": {
            "field": "x0"
          },
          "x2": {
            "field": "x1"
          },
          "y": {
            "field": "y0"
          },
          "y2": {
            "field": "y1"
          }
        }
      },
      "from": {
        "data": "branches"
      },
      "type": "rect"
    },
    {
      "encode": {
        "update": {
          "baseline": {
            "value": "middle"
          },
          "fill": {
            "field": "id",
            "scale": "color"
          },
          "fontSize": {
            "value": 11
          },
          "fontWeight": {
            "value": "bold"
          },
          "text": {
            "signal": "(datum.x1 - datum.x0) > 60 ? datum.id : ''"
          },
          "x": {
            "signal": "datum.x0 + 4"
          },
          "y": {
            "signal": "datum.y0 + 14"
          }
        }
      },
      "from": {
        "data": "branches"
      },
      "type": "text"
    },
    {
      "encode": {
        "enter": {
          "tooltip": {
            "signal": "{ 'Name': datum.id, 'Category': datum.parent, 'Size (MB)': datum.value }"
          }
        },
        "hover": {
          "fillOpacity": {
            "value": 0.8
          }
        },
        "update": {
          "cornerRadius": {
            "value": 2
          },
          "fill": {
            "signal": "scale('color', datum.parent)"
          },
          "stroke": {
            "value": "white"
          },
          "strokeWidth": {
            "value": 1
          },
          "x": {
            "field": "x0"
          },
          "x2": {
            "field": "x1"
          },
          "y": {
            "field": "y0"
          },
          "y2": {
            "field": "y1"
          }
        }
      },
      "from": {
        "data": "leaves"
      },
      "type": "rect"
    },
    {
      "encode": {
        "update": {
          "baseline": {
            "value": "middle"
          },
          "fill": {
            "value": "white"
          },
          "fontSize": {
            "value": 11
          },
          "fontWeight": {
            "value": "bold"
          },
          "text": {
            "signal": "(datum.x1 - datum.x0) > 40 && (datum.y1 - datum.y0) > 25 ? datum.id : ''"
          },
          "x": {
            "signal": "datum.x0 + 4"
          },
          "y": {
            "signal": "datum.y0 + 14"
          }
        }
      },
      "from": {
        "data": "leaves"
      },
      "type": "text"
    },
    {
      "encode": {
        "update": {
          "baseline": {
            "value": "middle"
          },
          "fill": {
            "value": "rgba(255,255,255,0.8)"
          },
          "fontSize": {
            "value": 10
          },
          "text": {
            "signal": "(datum.x1 - datum.x0) > 40 && (datum.y1 - datum.y0) > 40 ? datum.value + ' MB' : ''"
          },
          "x": {
            "signal": "datum.x0 + 4"
          },
          "y": {
            "signal": "datum.y0 + 27"
          }
        }
      },
      "from": {
        "data": "leaves"
      },
      "type": "text"
    }
  ],
  "padding": {
    "bottom": 16,
    "left": 24,
    "right": 24,
    "top": 16
  },
  "scales": [
    {
      "domain": [
        "Documents",
        "Media",
        "Applications",
        "System",
        "Downloads"
      ],
      "name": "color",
      "range": [
        "#1c7ed6",
        "#e8590c",
        "#0ca678",
        "#f03e3e",
        "#ae3ec9"
      ],
      "type": "ordinal"
    }
  ],
  "title": {
    "anchor": "start",
    "fontSize": 16,
    "offset": 16,
    "subtitle": "File system storage by category and subfolder (MB)",
    "subtitleColor": "#868e96",
    "subtitleFontSize": 12,
    "text": "Media (Videos + Photos) accounts for nearly half of total storage"
  },
  "width": 700
}
