{
  "_metadata": {
    "customization": [
      "Replace 'values' array in data[0] with your hierarchy",
      "Change 'name' field or add additional fields for richer tooltips",
      "Adjust tree transform 'method' ('tidy' or 'cluster') and 'size' for layout",
      "Update scales[0] (depthColor) domain and range for your depth levels",
      "Switch orientation by swapping x/y assignments in the tree transform 'as' array",
      "Modify title.text and description for your context"
    ],
    "dataFormat": "Array of objects with 'id' (unique string), 'parent' (string referencing another id, or null for root), and 'name' (display label) fields. Hierarchical parent-child structure.",
    "notes": "The tidy layout algorithm spaces nodes evenly. Use 'cluster' method to align leaf nodes at the same depth."
  },
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "config": {
    "aria": true,
    "axis": {
      "labelFont": "system-ui, -apple-system, sans-serif",
      "titleFont": "system-ui, -apple-system, sans-serif"
    },
    "title": {
      "font": "system-ui, -apple-system, sans-serif"
    },
    "view": {
      "stroke": null
    }
  },
  "data": [
    {
      "name": "tree",
      "transform": [
        {
          "key": "id",
          "parentKey": "parent",
          "type": "stratify"
        },
        {
          "as": [
            "y",
            "x",
            "depth",
            "children"
          ],
          "method": "tidy",
          "separation": true,
          "size": [
            {
              "signal": "height"
            },
            {
              "signal": "width - 160"
            }
          ],
          "type": "tree"
        }
      ],
      "values": [
        {
          "id": "1",
          "name": "Alex Chen (CEO)",
          "parent": null
        },
        {
          "id": "2",
          "name": "Jordan Smith (CTO)",
          "parent": "1"
        },
        {
          "id": "3",
          "name": "Riley Johnson (CFO)",
          "parent": "1"
        },
        {
          "id": "4",
          "name": "Drew Martinez (COO)",
          "parent": "1"
        },
        {
          "id": "5",
          "name": "Sam Lee (Engineer)",
          "parent": "2"
        },
        {
          "id": "6",
          "name": "Pat Wilson (Engineer)",
          "parent": "2"
        },
        {
          "id": "7",
          "name": "Morgan Davis (Product)",
          "parent": "2"
        },
        {
          "id": "8",
          "name": "Casey White (Controller)",
          "parent": "3"
        },
        {
          "id": "9",
          "name": "Jamie Green (Analyst)",
          "parent": "3"
        },
        {
          "id": "10",
          "name": "Avery Thompson (Ops)",
          "parent": "4"
        }
      ]
    },
    {
      "name": "links",
      "source": "tree",
      "transform": [
        {
          "type": "treelinks"
        },
        {
          "orient": "horizontal",
          "shape": "diagonal",
          "type": "linkpath"
        }
      ]
    }
  ],
  "description": "Organizational hierarchy tree diagram with tidy layout. Nodes represent people and departments with parent-child relationships shown as curved links.",
  "height": 500,
  "marks": [
    {
      "encode": {
        "update": {
          "path": {
            "field": "path"
          },
          "stroke": {
            "value": "#ccc"
          },
          "strokeWidth": {
            "value": 1.5
          }
        }
      },
      "from": {
        "data": "links"
      },
      "type": "path"
    },
    {
      "encode": {
        "enter": {
          "size": {
            "value": 200
          },
          "stroke": {
            "field": "depth",
            "scale": "depthColor"
          },
          "strokeWidth": {
            "value": 2
          },
          "tooltip": {
            "signal": "{ 'Name': datum.name, 'Depth': datum.depth, 'Children': datum.children }"
          }
        },
        "hover": {
          "stroke": {
            "value": "#333"
          },
          "strokeWidth": {
            "value": 3
          }
        },
        "update": {
          "fill": [
            {
              "test": "datum.children > 0",
              "value": "#fff"
            },
            {
              "field": "depth",
              "scale": "depthColor"
            }
          ],
          "x": {
            "field": "x"
          },
          "y": {
            "field": "y"
          }
        }
      },
      "from": {
        "data": "tree"
      },
      "type": "symbol"
    },
    {
      "encode": {
        "enter": {
          "baseline": {
            "value": "middle"
          },
          "fill": {
            "value": "#333"
          },
          "fontSize": {
            "value": 11
          },
          "text": {
            "field": "name"
          }
        },
        "update": {
          "align": {
            "signal": "datum.children > 0 ? 'right' : 'left'"
          },
          "dx": {
            "signal": "datum.children > 0 ? -10 : 10"
          },
          "x": {
            "field": "x"
          },
          "y": {
            "field": "y"
          }
        }
      },
      "from": {
        "data": "tree"
      },
      "type": "text"
    }
  ],
  "padding": {
    "bottom": 16,
    "left": 24,
    "right": 24,
    "top": 16
  },
  "scales": [
    {
      "domain": [
        0,
        1,
        2,
        3,
        4
      ],
      "name": "depthColor",
      "range": [
        "#1c7ed6",
        "#e8590c",
        "#0ca678",
        "#f03e3e",
        "#ae3ec9"
      ],
      "type": "ordinal"
    }
  ],
  "title": {
    "anchor": "start",
    "fontSize": 16,
    "offset": 16,
    "subtitle": "Organizational hierarchy — hover nodes for role details",
    "subtitleColor": "#868e96",
    "subtitleFontSize": 12,
    "text": "Engineering carries the deepest reporting chain under the CTO"
  },
  "width": 800
}
